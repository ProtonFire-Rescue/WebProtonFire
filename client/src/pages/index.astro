---
import Layout from "@/layouts/Layout.astro";
import Menu from "@/components/page/Menu.astro";
import Footer from "@/components/page/Footer.astro";
import Destacados from "@/components/react-island/Destacados";
import InfiniteCarousel from "@/components/InfiniteCarousel.astro";
import { ChevronRight } from "lucide-react";
import WhatsAppWidget from "@/components/WhatsAppWidget.astro";
import CTAButton from "@/components/ui/CTAButton.astro";
import { Image } from "astro:assets";

const currentPath = Astro.url.pathname;


const productCategories = [
	{
		name: "Línea Fuego",
		description:
			"Equipos especializados para la extinción de incendios y protección contra fuego",
		image: "/images/linea-fuego.webp",
		url: "/productos#forestal",
		category: "forestal",
		products: [
			"Extintores",
			"Mangueras",
			"Trajes",
		],
	},
	{
		name: "Línea Rescate",
		category: "rescate",
		url:"/productos#rescate",
		description:
			"Equipos para operaciones de rescate y salvamento en emergencias",
		image: "/images/linea-rescate.webp",
		products: ["Accesorios", "Estabilizadores", "Herramientas de rescate"],
	},
	{
		name: "Línea Tecnología",
		category: "tecnologia",
		url:"#destacados",
		description:
			"Soluciones tecnológicas avanzadas para entrenamiento y operaciones",
		image: "/images/linea-tecnologia.webp",
		products: ["F-500", "FLAIM VR", "Equipos Eléctricos"],
	},
];

// Imágenes para carousel de marcas
const brandImages = [
	{ src: "/brands/f500.png", alt: "F500 Agente Encapsulador de Alta Tecnología" },
	{ src: "/brands/sicor.png", alt: "Sicor marca Italiana líder, equipos de protección" },
	{ src: "/brands/viking.png", alt: "Viking lider en el sector de seguridad y protección" },
	{ src: "/brands/carbon-x.png", alt: "Carbon X marca de textiles de alto rendimiento" },
];

// Imágenes para carousel de certificaciones
const certificationImages = [
	{ src: "/certifications/cert1.png", alt: "Certificación National Fire Protection Association (NFPA)" },
	{ src: "/certifications/cert2.png", alt: "Certificación KFI (Korean Firer Institue)" },
	{ src: "/certifications/cert3.png", alt: "Certificación EN (Normas Europeas)" },
	{ src: "/certifications/cert4.png", alt: "Certificación UL Classified" },
	{ src: "/certifications/cert5.png", alt: "Certificación forestal US Forest Service (USFS)" },
	{ src: "/certifications/cert6.png", alt: "Certificación FM Approved" },
	{ src: "/certifications/cert7.png", alt: "Certificación NIOSH (National Institute for Occupational Safety and Health)" },
	{ src: "/certifications/cert8.png", alt: "Certificación EN 469 (o UNE-EN 469)" },
	{ src: "/certifications/cert9.png", alt: "Certificación International Standard Worldwide" },
	{ src: "/certifications/cert10.png", alt: "Certificación ATEX (del francés ATmosphères EXplosibles)" },
];

const siteOrigin = Astro.url.origin;

// Structured Data para la página de inicio
const homePageSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": siteOrigin, 
  "name": "PROTON Fire & Rescue Ecuador",
  "description": "Empresa ecuatoriana especializada en equipos de seguridad para bomberos, rescate e industria con más de 20 años de experiencia.",
  "url": siteOrigin,
  "logo": `${siteOrigin}/logos/proton-logo.png`,
  "image": `${siteOrigin}/images/og/og_home.webp`,
  "telephone": "+593992526658",
  "email": "info@protonfire.com",
  "priceRange": "$$",
  "slogan": "Protegiendo vidas, asegurando el futuro",
  "foundingDate": "2000",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Raúl González y Chimborazo Oe2-91",
    "addressLocality": "Quito",
    "postalCode": "170136",
    "addressCountry": "EC"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -0.20154376685984446,
    "longitude": -78.43466760636124
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday"
      ],
      "opens": "08:00",
      "closes": "17:00"
    }
  ],
  "sameAs": [
    "https://www.facebook.com/protonFireRescue",
    "https://www.instagram.com/proton_fire_/",
    "https://www.youtube.com/@protonfirerescue2360"
  ],
  "areaServed": {
    "@type": "Country",
    "name": "Ecuador"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Equipos de Seguridad",
    "itemListElement": [
      {
        "@type": "OfferCatalog",
        "name": "Línea Fuego",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Product",
              "name": "Equipos contra incendios"
            }
          }
        ]
      },
      {
        "@type": "OfferCatalog",
        "name": "Línea Rescate",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Product",
              "name": "Equipos de rescate"
            }
          }
        ]
      },
      {
        "@type": "OfferCatalog",
        "name": "Línea Tecnología",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Product",
              "name": "Tecnología para bomberos"
            }
          }
        ]
      }
    ]
  }
}
---

<Layout
	title="PROTON Fire & Rescue Ecuador | Equipos Bomberos, Rescate e Industria"
	description="Empresa ecuatoriana líder con +20 años en equipos de seguridad para bomberos, rescate e industria. Importadores de FLAIM VR, F-500 EA y equipos certificados. Servicio en todo Ecuador."
	keywords="equipos bomberos Ecuador, equipos rescate Ecuador, PROTON Fire Rescue, equipos seguridad industrial Ecuador, FLAIM Ecuador, F-500 Ecuador, equipos contra incendios, trajes bombero Ecuador, equipos emergencia"
	jsonLd={homePageSchema}
>
	<Menu currentPath={currentPath} />
	
	<WhatsAppWidget />

	<main class="min-h-screen dark:bg-[#0b0b12]">
		<!-- Hero Section - Dark with firefighters background -->
		<section
			class="relative min-h-150 md:min-h-175 py-30 md:py-50 overflow-hidden md:mx-5 md:rounded-[55px]"
		>
			<!-- Background Image with overlay -->
			<div class="absolute inset-0">
				<video
					src="/videos/home.mp4"
					class="w-full h-full object-cover"
					autoplay
					muted
					loop
					playsinline></video>
				<div class="absolute inset-0 bg-black/60"></div>
			</div>

			<div
				class="relative z-10 max-w-360 mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 pt-30 md:pt-10 pb-20"
			>
				<div class="max-w-2xl">
					<span
						class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 text-xs md:text-sm font-semibold px-4 py-1.5 rounded-full mb-6"
						data-aos="fade-down" data-aos-delay="100"
					>
						<span
							class="w-2 h-2 bg-green-400 rounded-full animate-pulse"
						></span>
						+20 años protegiendo vidas en Ecuador
					</span>
					<h1
						class="text-4xl md:text-5xl lg:text-[59px] font-bold text-white leading-tight mb-6"
						data-aos="fade-up" data-aos-delay="200"
					>
						Proton Fire & Rescue
					</h1>
					<p
						class="text-sm md:text-lg text-white/80 leading-relaxed mb-10 max-w-xl"
						data-aos="fade-up" data-aos-delay="300"
					>
						Somos una empresa ecuatoriana con más de 2 décadas de
						trayectoria en el mercado nacional. Nos especializamos
						en la importación y comercialización de equipos de
						seguridad para los sectores bomberil, de rescate e
						industrial, consolidándonos como un referente de
						confianza en el país.
					</p>
					<div class="flex flex-col sm:flex-row gap-4" data-aos="fade-up" data-aos-delay="400">
						<CTAButton href="/productos">
							Ver Productos
							<ChevronRight />
						</CTAButton>
						<a
							href="/contactanos"
							class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm border border-white/30 text-white font-semibold px-8 py-4 rounded-full hover:bg-white/20 transition-all duration-300 hover:-translate-y-0.5"
						>
							Contáctanos
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Presencia Global Section -->
		<section
			class="flex justify-center py-40 bg-linear-to-b from-orange-50 via-white to-red-50 dark:from-[#0b0b12] dark:via-[#12121e] dark:to-[#0b0b12]"
		>
			<div class="max-w-[1420px] mx-auto px-4">
				<div class="rounded-3xl p-8 md:p-12 lg:p-16">
					<h2
						class="text-3xl md:text-4xl lg:text-[52px] font-bold text-[#2f2f3b] dark:text-white text-center mb-8"
						data-aos="fade-up"
					>
						Presencia global
					</h2>
					<p
						class="text-lg text-[#6b7280] dark:text-[#9ca3b8] text-center max-w-[989px] mx-auto mb-8"
						data-aos="fade-up" data-aos-delay="100"
					>
						Con una visión abierta al mundo, PROTON Fire & Rescue
						participa activamente en los eventos de seguridad más
						importantes del planeta, como la FDIC en Estados Unidos
						y la INTERSCHUTZ en Alemania.
					</p>

					<div
						class="bg-[#504aff] rounded-xl p-6 md:p-8 mb-8 max-w-[1059px] mx-auto"
						data-aos="zoom-in" data-aos-delay="200"
					>
						<p class="text-white text-lg text-center">
							Nuestro compromiso con la seriedad y la innovación
							nos lleva a estar presentes en las ferias
							comerciales más grandes del mundo para seguir
							contribuyendo al éxito de las organizaciones
							locales.
						</p>
					</div>

					<div class="text-center" data-aos="fade-up" data-aos-delay="300">
						<CTAButton href="/nosotros">
							Conócenos
							<ChevronRight />
						</CTAButton>
					</div>
				</div>
			</div>
		</section>

		<!-- Líneas de Especialidad Section - Dark Background -->
		<section class="py-20 bg-[#2f2f3b] dark:bg-[#08080e]">
			<div class="max-w-[1414px] mx-auto px-4">
				<h2
					class="text-xl md:text-2xl lg:text-[52px] font-bold text-white text-center mb-12"
					data-aos="fade-up"
				>
					Nuestras líneas de especialidad
				</h2>

				<div class="grid md:grid-cols-3 gap-8">
					{
						productCategories.map((category) => (
							<a
								href={category.url}
								class="group relative overflow-hidden rounded-2xl"
								data-aos="fade-up"
							>
								<div class="relative h-[413px] overflow-hidden">
									<Image
										src={category.image}
										alt={category.name}
										class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
										width={413}
										height={413}
									/>
									<div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/40 to-transparent" />
								</div>
								<div class="absolute bottom-0 left-0 right-0 p-6">
									<h3 class="text-2xl font-bold text-white mb-2">
										{category.name}
									</h3>
									<p class="text-zinc-200 mb-2">
										{category.description}
									</p>

									<div class="flex gap-2">
										{
											category.products.map((product) => {
												return <div class="bg-white/20 flex items-center justify-center backdrop-blur-sm text-white text-xs font-medium px-3 py-1 rounded-full">
													{product}
												</div>
											})
										}
									</div>
								</div>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<!-- Servicios Adicionales Section -->
		<section class="py-20 bg-white dark:bg-[#0b0b12]">
			<div class="max-w-[1414px] mx-auto px-4">
				<h2
					class="text-3xl md:text-4xl lg:text-[57px] font-bold text-[#2f2f3b] dark:text-white text-center mb-4"
					data-aos="fade-up"
				>
					Servicios adicionales
				</h2>
				<p
					class="text-lg text-[#6b7280] dark:text-[#9ca3b8] text-center max-w-[617px] mx-auto mb-8"
					data-aos="fade-up" data-aos-delay="100"
				>
					Además de ofrecer productos, Proton Fire & Rescue ofrece un
					catálogo de servicios varios que te pueden interesar.
				</p>

				<div class="flex flex-wrap justify-center gap-4 mb-16" data-aos="fade-up" data-aos-delay="200">
					<span
						class="bg-[#504aff] text-white px-6 py-2 rounded-full text-sm font-semibold"
						>Capacita</span
					>
					<span
						class="bg-[#504aff] text-white px-6 py-2 rounded-full text-sm font-semibold"
						>Confecciona</span
					>
					<span
						class="bg-[#504aff] text-white px-6 py-2 rounded-full text-sm font-semibold"
						>Mantiene</span
					>
				</div>

				<div class="grid md:grid-cols-3 gap-6">
					<!-- Capacitación -->
					<div
						class="bg-gradient-to-r from-slate-900 to-slate-700 rounded-2xl py-10 px-6 shadow-lg border border-gray-100 dark:border-white/5 hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
						data-aos="fade-up" data-aos-delay="100"
					>
						<div
							class="w-[120px] h-[120px] bg-white/40 rounded-full flex items-center justify-center mx-auto mb-6"
						>
							<Image
								src="/icons/capacitacion.png"
								alt="Servicio de capacitación"
								class="w-[70px] h-[70px] object-contain"
								width={70}
								height={70}	
							/>
						</div>
						<h3
							class="text-lg font-bold text-white mb-4 text-center"
						>
							SERVICIOS DE CAPACITACIÓN
						</h3>
						<p
							class="text-zinc-200 text-sm leading-relaxed text-center"
						>
							PROTON Fire & Rescue ofrece capacitación
							especializada y formación de brigadas en rescate,
							primeros auxilios y trabajos de alto riesgo. Somos
							expertos en la gestión de materiales peligrosos
							(Hazmat) y seguridad en altura, brindando soluciones
							técnicas integrales para que su industria opere bajo
							los más altos estándares de seguridad.
						</p>
					</div>

					<!-- Confección -->
					<div
						class="bg-gradient-to-r from-slate-900 to-slate-700 rounded-2xl py-10 px-6 shadow-lg border border-gray-100 dark:border-white/5 hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
						data-aos="fade-up" data-aos-delay="200"
					>
						<div
							class="w-[120px] h-[120px] bg-white/40 rounded-full flex items-center justify-center mx-auto mb-6"
						>
							<Image
								src="/icons/confeccion.png"
								alt="Servicio de Confección"
								class="w-[70px] h-[70px] object-contain"
								width={70}
								height={70}
							/>
						</div>
						<h3
							class="text-lg font-bold text-white mb-4 text-center"
						>
							SERVICIOS DE CONFECCIÓN
						</h3>
						<p
							class="text-zinc-200 text-sm leading-relaxed text-center"
						>
							Confeccionamos prendas técnicas de alta protección
							(ignífugas, dieléctricas y antidesgarro) utilizando
							insumos 100% certificados. Nuestras soluciones
							textiles garantizan seguridad avanzada contra
							riesgos específicos, combinando materiales
							especializados con componentes de alta durabilidad
							para entornos industriales exigentes.
						</p>
					</div>

					<!-- Mantenimiento -->
					<div
						class="bg-gradient-to-r from-slate-900 to-slate-700 rounded-2xl py-10 px-6 shadow-lg border border-gray-100 dark:border-white/5 hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
						data-aos="fade-up" data-aos-delay="300"
					>
						<div
							class="w-[120px] h-[120px] bg-white/40 rounded-full flex items-center justify-center mx-auto mb-6"
						>
							<Image
								src="/icons/mantenimiento.png"
								alt="Servicio de mantenimiento"
								class="w-[70px] h-[70px] object-contain"
								width={70}
								height={70}
							/>
						</div>
						<h3
							class="text-lg font-bold text-white mb-4 text-center"
						>
							SERVICIOS DE MANTENIMIENTO
						</h3>
						<p
							class="text-zinc-200 text-sm leading-relaxed text-center"
						>
							Ofrecemos un servicio técnico integral y
							mantenimiento especializado para equipos de
							protección crítica. Realizamos pruebas
							hidrostáticas, recarga de aire respirable tipo D y
							reparación certificada de equipos SCBA y sistemas
							para trabajos en altura, garantizando siempre la
							máxima operatividad y seguridad de su equipamiento.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Productos Destacados Section -->
		<section
			class="py-40 bg-gradient-to-b from-purple-50 via-white to-blue-50 dark:from-[#0b0b12] dark:via-[#12121e] dark:to-[#0b0b12]"
			id="destacados"
		>
			<div class="max-w-[1414px] mx-auto px-4">
				<h2
					class="text-3xl md:text-4xl lg:text-[52px] font-bold text-[#2f2f3b] dark:text-white text-center mb-4"
					data-aos="fade-up"
				>
					Nuestros productos destacados
				</h2>
				<p
					class="text-lg text-[#6b7280] dark:text-[#9ca3b8] text-center max-w-[692px] mx-auto mb-12"
					data-aos="fade-up" data-aos-delay="100"
				>
					Contamos con una variedad de productos; te presentamos los
					que más llaman la atención de nuestros clientes.
				</p>

				<Destacados client:visible />
			</div>
		</section>

		<!-- Marcas Section -->
		<section class="py-16 bg-white dark:bg-[#0b0b12]">
			<div class="max-w-[1440px] mx-auto px-4">
				<h2
					class="text-2xl md:text-3xl font-bold text-[#2f2f3b] dark:text-white text-center mb-4"
					data-aos="fade-up"
				>
					Nuestras prestigiosas marcas
				</h2>
				<p
					class="text-lg text-[#6b7280] dark:text-[#9ca3b8] text-center max-w-[632px] mx-auto mb-12"
				>
					Trabajamos con las marcas más reconocidas del mercado para
					garantizar la mejor calidad y rendimiento.
				</p>

				<InfiniteCarousel
					images={brandImages}
					speed={20}
					direction="left"
				/>
			</div>
		</section>
		<hr class="my-15 mx-5 border-gray-200 dark:border-[#2a2a3e] h-px" />
		<!-- Certificaciones Section -->
		<section class="py-16 bg-white dark:bg-[#0b0b12]">
			<div class="max-w-[1440px] mx-auto px-4">
				<h2
					class="text-2xl md:text-3xl font-bold text-[#2f2f3b] dark:text-white text-center mb-4"
					data-aos="fade-up"
				>
					Certificaciones
				</h2>
				<p
					class="text-lg text-[#6b7280] dark:text-[#9ca3b8] text-center max-w-[632px] mx-auto mb-12"
				>
					Nos encargamos de distribuir productos que cumplan con
					certificaciones internacionales.
				</p>

				<InfiniteCarousel
					images={certificationImages}
					speed={30}
					direction="right"
				/>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
