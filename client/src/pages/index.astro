---
import Layout from "../layouts/Layout.astro";
import Menu from "../components/Menu.astro";
import Footer from "../components/Footer.astro";
import Destacados from "../components/sections/Destacados";
import InfiniteCarousel from "../components/InfiniteCarousel.astro";
import { ChevronRight } from "lucide-react";

const currentPath = Astro.url.pathname;

const productCategories = [
	{
		name: "Línea Fuego",
		description:
			"Equipos especializados para la extinción de incendios y protección contra fuego",
		image: "./images/linea-fuego.png",
		products: [
			"Extintores",
			"Mangueras",
			"Equipos de respiración",
			"Trajes de bombero",
		],
	},
	{
		name: "Línea Rescate",
		description:
			"Equipos para operaciones de rescate y salvamento en emergencias",
		image: "./images/linea-rescate.png",
		products: ["Cuerdas", "Arnés", "Poleas", "Herramientas de rescate"],
	},
	{
		name: "Línea Tecnología",
		description:
			"Soluciones tecnológicas avanzadas para entrenamiento y operaciones",
		image: "./images/linea-tecnologia.png",
		products: ["F-500", "FLAIM VR", "Sistemas de monitoreo"],
	},
];

// Imágenes para carousel de marcas
const brandImages = [
	{ src: "/brands/f500.png", alt: "F500" },
	{ src: "/brands/sicor.png", alt: "Sicor" },
	{ src: "/brands/viking.png", alt: "Viking" },
	{ src: "/brands/task.png", alt: "Task" },
	{ src: "/brands/hystec.png", alt: "Hystec" },
	{ src: "/brands/gvs.png", alt: "GVS" },
];

// Imágenes para carousel de certificaciones
const certificationImages = [
	{ src: "/certifications/cert1.png", alt: "Certificación 1" },
	{ src: "/certifications/cert2.png", alt: "Certificación 2" },
	{ src: "/certifications/cert3.png", alt: "Certificación 3" },
	{ src: "/certifications/cert4.png", alt: "Certificación 4" },
	{ src: "/certifications/cert5.png", alt: "Certificación 5" },
	{ src: "/certifications/cert6.png", alt: "Certificación 6" },
	{ src: "/certifications/cert7.png", alt: "Certificación 7" },
	{ src: "/certifications/cert8.png", alt: "Certificación 8" },
	{ src: "/certifications/cert9.png", alt: "Certificación 9" },
	{ src: "/certifications/cert10.png", alt: "Certificación 10" },
];
---

<Layout
	title="PROTON Fire & Rescue - Equipos de Seguridad Ecuador"
	description="Empresa ecuatoriana con más de 2 décadas de trayectoria en importación y comercialización de equipos de seguridad para bomberos, rescate e industria."
	url="https://protonfire.com"
>
	<Menu currentPath={currentPath} />

	<main>
		<!-- Hero Section - Dark with firefighters background -->
		<section
			class="relative min-h-150 md:min-h-200 py-30 md:py-65 overflow-hidden md:mx-5 md:rounded-[55px]"
		>
			<!-- Background Image with overlay -->
			<div class="absolute inset-0">
				<video
					src="/videos/home.mp4"
					class="w-full h-full object-cover"
					autoplay
					muted
					loop
					playsinline
				/>
				<div class="absolute inset-0 bg-black/60"></div>
			</div>

			<div
				class="relative z-10 max-w-360 mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 pt-30 md:pt-10 pb-20"
			>
				<div class="max-w-2xl">
					<h1
						class="text-4xl md:text-5xl lg:text-[59px] font-bold text-white leading-tight mb-6"
					>
						Proton Fire & Rescue
					</h1>
					<p class="text-sm md:text-lg text-white/90 leading-relaxed">
						Somos una empresa ecuatoriana con más de 2 decadas de
						trayectoria en el mercado nacional. Nos especializamos
						en la importación y comercialización de equipos de
						seguridad para los sectores bomberil, de rescate e
						industrial, consolidándonos como un referente de
						confianza en el país.
					</p>
				</div>
			</div>
		</section>

		<!-- Presencia Global Section -->
		<section class="flex justify-center py-40 bg-white">
			<div class="max-w-[1420px] mx-auto px-4">
				<div class="rounded-3xl p-8 md:p-12 lg:p-16">
					<h2
						class="text-3xl md:text-4xl lg:text-[52px] font-bold text-[#2f2f3b] text-center mb-8"
					>
						Presencia global
					</h2>
					<p
						class="text-lg text-[#6b7280] text-center max-w-[989px] mx-auto mb-8"
					>
						Con una visión abierta al mundo, PROTON Fire & Rescue
						participa activamente en los eventos de seguridad más
						importantes del planeta, como la FDIC en Estados Unidos
						y la INTERSCHUTZ en Alemania.
					</p>

					<div
						class="bg-[#504aff] rounded-xl p-6 md:p-8 mb-8 max-w-[1059px] mx-auto"
					>
						<p class="text-white text-lg text-center">
							Nuestro compromiso con la seriedad y la innovación
							nos lleva a estar presentes en las ferias
							comerciales más grandes del mundo para seguir
							contribuyendo al éxito de las organizaciones
							locales.
						</p>
					</div>

					<div class="text-center">
						<a
							href="/nosotros"
							class="inline-flex items-center gap-2 bg-[#504aff] text-white font-semibold px-8 py-4 rounded-[25px] hover:bg-[#3f3bcc] transition-colors"
						>
							Conocenos
							<ChevronRight />
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Líneas de Especialidad Section - Dark Background -->
		<section class="py-20 bg-[#2f2f3b]">
			<div class="max-w-[1414px] mx-auto px-4">
				<h2
					class="text-xl md:text-2xl lg:text-[52px] font-bold text-white text-center mb-12"
				>
					Nuestras líneas de especialidad
				</h2>

				<div class="grid md:grid-cols-3 gap-8">
					{
						productCategories.map((category) => (
							<a
								href={`/productos/category/${category.name.toLowerCase().replace(" ", "-")}`}
								class="group relative overflow-hidden rounded-2xl"
							>
								<div class="relative h-[413px] overflow-hidden">
									<img
										src={category.image}
										alt={category.name}
										class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
									/>
									<div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/40 to-transparent" />
								</div>
								<div class="absolute bottom-0 left-0 right-0 p-6">
									<h3 class="text-2xl font-bold text-white mb-2">
										{category.name}
									</h3>
									<span class="text-white/80 font-light">
										Leer más
									</span>
								</div>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<!-- Servicios Adicionales Section -->
		<section class="py-20 bg-white">
			<div class="max-w-[1414px] mx-auto px-4">
				<h2
					class="text-3xl md:text-4xl lg:text-[57px] font-bold text-[#2f2f3b] text-center mb-4"
				>
					Servicios adicionales
				</h2>
				<p
					class="text-lg text-[#6b7280] text-center max-w-[617px] mx-auto mb-8"
				>
					Además de ofrecer productos, Proton Fire & Rescue ofrece un
					catálogo de servicios varios que te pueden interesar.
				</p>

				<div class="flex flex-wrap justify-center gap-4 mb-16">
					<span
						class="bg-[#504aff] text-white px-6 py-2 rounded-full text-sm font-semibold"
						>Capacita</span
					>
					<span
						class="bg-[#504aff] text-white px-6 py-2 rounded-full text-sm font-semibold"
						>Confecciona</span
					>
					<span
						class="bg-[#504aff] text-white px-6 py-2 rounded-full text-sm font-semibold"
						>Mantiene</span
					>
				</div>

				<div class="grid md:grid-cols-3 gap-6">
					<!-- Capacitación -->
					<div
						class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100"
					>
						<div
							class="w-[120px] h-[120px] bg-[#f8f9fa] rounded-full flex items-center justify-center mx-auto mb-6"
						>
							<img
								src="/icons/capacitacion.png"
								alt="Capacitación"
								class="w-[70px] h-[70px] object-contain"
							/>
						</div>
						<h3
							class="text-lg font-bold text-[#2f2f3b] mb-4 text-center"
						>
							SERVICIOS DE CAPACITACIÓN
						</h3>
						<p
							class="text-[#6b7280] text-sm leading-relaxed text-center"
						>
							PROTON Fire & Rescue ofrece capacitación
							especializada y formación de brigadas en rescate,
							primeros auxilios y trabajos de alto riesgo. Somos
							expertos en la gestión de materiales peligrosos
							(Hazmat) y seguridad en altura, brindando soluciones
							técnicas integrales para que su industria opere bajo
							los más altos estándares de seguridad.
						</p>
					</div>

					<!-- Confección -->
					<div
						class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100"
					>
						<div
							class="w-[120px] h-[120px] bg-[#f8f9fa] rounded-full flex items-center justify-center mx-auto mb-6"
						>
							<img
								src="/icons/confeccion.png"
								alt="Confección"
								class="w-[70px] h-[70px] object-contain"
							/>
						</div>
						<h3
							class="text-lg font-bold text-[#2f2f3b] mb-4 text-center"
						>
							SERVICIOS DE CONFECCIÓN
						</h3>
						<p
							class="text-[#6b7280] text-sm leading-relaxed text-center"
						>
							Confeccionamos prendas técnicas de alta protección
							(ignífugas, dieléctricas y antidesgarro) utilizando
							insumos 100% certificados. Nuestras soluciones
							textiles garantizan seguridad avanzada contra
							riesgos específicos, combinando materiales
							especializados con componentes de alta durabilidad
							para entornos industriales exigentes.
						</p>
					</div>

					<!-- Mantenimiento -->
					<div
						class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100"
					>
						<div
							class="w-[120px] h-[120px] bg-[#f8f9fa] rounded-full flex items-center justify-center mx-auto mb-6"
						>
							<img
								src="/icons/mantenimiento.png"
								alt="Mantenimiento"
								class="w-[70px] h-[70px] object-contain"
							/>
						</div>
						<h3
							class="text-lg font-bold text-[#2f2f3b] mb-4 text-center"
						>
							SERVICIOS DE MANTENIMIENTO
						</h3>
						<p
							class="text-[#6b7280] text-sm leading-relaxed text-center"
						>
							Ofrecemos un servicio técnico integral y
							mantenimiento especializado para equipos de
							protección crítica. Realizamos pruebas
							hidrostáticas, recarga de aire respirable tipo D y
							reparación certificada de equipos SCBA y sistemas
							para trabajos en altura, garantizando siempre la
							máxima operatividad y seguridad de su equipamiento.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Productos Destacados Section -->
		<section
			class="py-40 bg-gradient-to-b from-white via-zinc-200 to-zinc-10"
		>
			<div class="max-w-[1414px] mx-auto px-4">
				<h2
					class="text-3xl md:text-4xl lg:text-[52px] font-bold text-[#2f2f3b] text-center mb-4"
				>
					Nuestros productos destacados
				</h2>
				<p
					class="text-lg text-[#6b7280] text-center max-w-[692px] mx-auto mb-12"
				>
					Contamos con una variedad de productos; te presentamos los
					que más llaman la atención de nuestros clientes.
				</p>

				<Destacados client:load />
			</div>
		</section>

		<!-- Marcas Section -->
		<section class="py-16 bg-white">
			<div class="max-w-[1440px] mx-auto px-4">
				<h2
					class="text-2xl md:text-3xl font-bold text-[#2f2f3b] text-center mb-4"
				>
					Nuestras prestigiosas marcas
				</h2>
				<p
					class="text-lg text-[#6b7280] text-center max-w-[632px] mx-auto mb-12"
				>
					Trabajamos con las marcas más reconocidas del mercado para
					garantizar la mejor calidad y rendimiento.
				</p>

				<InfiniteCarousel
					images={brandImages}
					speed={20}
					direction="left"
				/>
			</div>
		</section>

		<!-- Certificaciones Section -->
		<section class="py-16 bg-[#f8f9fa]">
			<div class="max-w-[1440px] mx-auto px-4">
				<h2
					class="text-2xl md:text-3xl font-bold text-[#2f2f3b] text-center mb-4"
				>
					Certificaciones
				</h2>
				<p
					class="text-lg text-[#6b7280] text-center max-w-[632px] mx-auto mb-12"
				>
					Nos encargamos de distribuir productos que cumplan con
					certificaciones internacionales.
				</p>

				<InfiniteCarousel
					images={certificationImages}
					speed={30}
					direction="right"
				/>
			</div>
		</section>

		<!-- WhatsApp Float Button -->
		<div class="fixed bottom-6 right-6 z-50">
			<a
				href="https://wa.me/593XXXXXXXXX"
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center justify-center w-[60px] h-[60px] bg-[#25d366] rounded-full shadow-lg hover:shadow-xl transition-shadow"
				aria-label="Contactar por WhatsApp"
			>
				<svg
					class="w-8 h-8 text-white"
					fill="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.521.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
					></path>
				</svg>
			</a>
		</div>
	</main>

	<Footer />
</Layout>
