---
import Layout from "@/layouts/Layout.astro";
import Menu from "@/components/page/Menu.astro";
import Footer from "@/components/page/Footer.astro";
import Destacados from "@/components/react-island/Destacados";
import InfiniteCarousel from "@/components/InfiniteCarousel.astro";
import BrandsCarouselData from "@/components/BrandsCarouselData.astro";
import InfoCard from "@/components/ui/InfoCard.astro"
import WhatsAppWidget from "@/components/WhatsAppWidget.astro";
import CTAButton from "@/components/ui/CTAButton.astro";
import { Image } from "astro:assets";
import { ChevronRight } from "lucide-react";

const currentPath = Astro.url.pathname;

const productCategories = [
	{
		name: "Línea Fuego",
		description:
			"Equipos especializados para la extinción de incendios y protección contra fuego",
		image: "/images/linea-fuego.webp",
		url: "/catalogo/Forestal",
		category: "forestal",
		products: ["Botas", "Cascos", "Trajes"],
	},
	{
		name: "Línea Rescate",
		category: "rescate",
		url: "/catalogo/Rescate",
		description:
			"Equipos para operaciones de rescate y salvamento en emergencias",
		image: "/images/linea-rescate.webp",
		products: ["Accesorios", "Estabilizadores", "Herramientas de rescate"],
	},
	{
		name: "Línea Tecnología",
		category: "tecnologia",
		url: "#destacados",
		description:
			"Soluciones tecnológicas avanzadas para entrenamiento y operaciones",
		image: "/images/linea-tecnologia.webp",
		products: ["F-500", "FLAIM VR", "Equipos Eléctricos"],
	},
	{
		name: "Accesorios",
		category: "accesorios",
		url: "/catalogo/Accesorios",
		description: "Accesorios para equipos de protección y rescate",
		image: "/images/accesorios.webp",
		products: ["Accesorios Complementarios"],
	},
	{
		name: "Equipos",
		category: "equipos",
		url: "/catalogo/Rescate?type=Extricación",
		description: "Equipos para operaciones de emergencia",
		image: "/images/equipos.webp",
		products: ["Estabilizadores", "Herramientas de rescate"],
	},
];


// Imágenes para carousel de certificaciones
const certificationImages = [
	{
		src: "/certifications/cert1.png",
		alt: "Certificación National Fire Protection Association (NFPA)",
	},
	{
		src: "/certifications/cert2.png",
		alt: "Certificación KFI (Korean Fire Institute)",
	},
	{
		src: "/certifications/cert3.png",
		alt: "Certificación EN (Normas Europeas)",
	},
	{ src: "/certifications/cert4.png", alt: "Certificación UL Classified" },
	{
		src: "/certifications/cert5.png",
		alt: "Certificación forestal US Forest Service (USFS)",
	},
	{ src: "/certifications/cert6.png", alt: "Certificación FM Approved" },
	{
		src: "/certifications/cert7.png",
		alt: "Certificación NIOSH (National Institute for Occupational Safety and Health)",
	},
	{
		src: "/certifications/cert8.png",
		alt: "Certificación EN 469 (o UNE-EN 469)",
	},
	{
		src: "/certifications/cert9.png",
		alt: "Certificación International Standard Worldwide",
	},
	{
		src: "/certifications/cert10.png",
		alt: "Certificación ATEX (del francés ATmosphères EXplosibles)",
	},
];

const siteOrigin = Astro.url.origin;

// Structured Data para la página de inicio
const homePageSchema = {
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	"@id": `${siteOrigin}/#localbusiness`,
	name: "PROTON Fire & Rescue Ecuador",
	description:
		"Empresa ecuatoriana especializada en la importación y comercialización de equipos de seguridad para bomberos, rescate e industria con más de 2 décadas de experiencia. Distribuidores autorizados de marcas internacionales certificadas NFPA, EN, ISO y UL.",
	url: siteOrigin,
	logo: {
		"@type": "ImageObject",
		url: `${siteOrigin}/logos/proton-logo.webp`,
		width: 300,
		height: 200,
	},
	image: [
		`${siteOrigin}/images/og/og_home.webp`,
		`${siteOrigin}/images/hero-home.webp`,
	],
	telephone: "+593992526658",
	email: "info@protonfire.com",
	priceRange: "$$",
	slogan: "Protegiendo vidas, asegurando el futuro",
	foundingDate: "2000",
	currenciesAccepted: "USD",
	paymentAccepted: "Transferencia Bancaria, Efectivo",
	address: {
		"@type": "PostalAddress",
		streetAddress: "Raúl González y Chimborazo Oe2-91",
		addressLocality: "Quito",
		addressRegion: "Pichincha",
		postalCode: "170136",
		addressCountry: "EC",
	},
	geo: {
		"@type": "GeoCoordinates",
		latitude: -0.20154376685984446,
		longitude: -78.43466760636124,
	},
	openingHoursSpecification: [
		{
			"@type": "OpeningHoursSpecification",
			dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
			opens: "08:00",
			closes: "17:00",
		},
	],
	sameAs: [
		"https://www.facebook.com/protonFireRescue",
		"https://www.instagram.com/proton_fire_/",
		"https://www.youtube.com/@protonfirerescue2360",
	],
	areaServed: {
		"@type": "Country",
		name: "Ecuador",
	},
	numberOfEmployees: {
		"@type": "QuantitativeValue",
		minValue: 10,
		maxValue: 50,
	},
	knowsAbout: [
		"Equipos de protección contra incendios",
		"Equipos de rescate vehicular",
		"Trajes estructurales y forestales para bomberos",
		"Agente encapsulador F-500 EA",
		"FLAIM - Realidad virtual para entrenamiento de bomberos",
		"Equipos SCBA y compresores de aire respirable",
		"Herramientas de rescate hidráulicas y eléctricas",
	],
	hasOfferCatalog: {
		"@type": "OfferCatalog",
		name: "Equipos de Seguridad",
		itemListElement: [
			{
				"@type": "OfferCatalog",
				name: "Línea Fuego",
				description:
					"Equipos especializados para la extinción de incendios y protección contra fuego: trajes estructurales, cascos, botas, guantes y SCBA.",
				url: `${siteOrigin}/catalogo/Estructural`,
				itemListElement: [
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Product",
							name: "Trajes estructurales",
							url: `${siteOrigin}/catalogo/Estructural`,
						},
					},
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Product",
							name: "Cascos de bombero",
							url: `${siteOrigin}/catalogo/Estructural`,
						},
					},
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Product",
							name: "F-500 EA Agente Encapsulador",
							url: `${siteOrigin}/productos/f-500`,
						},
					},
				],
			},
			{
				"@type": "OfferCatalog",
				name: "Línea Rescate",
				description:
					"Equipos para operaciones de rescate vehicular, en altura y espacios confinados.",
				url: `${siteOrigin}/catalogo/Rescate`,
				itemListElement: [
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Product",
							name: "Herramientas de rescate hidráulicas",
							url: `${siteOrigin}/catalogo/Rescate`,
						},
					},
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Product",
							name: "Estabilizadores",
							url: `${siteOrigin}/catalogo/Rescate`,
						},
					},
				],
			},
			{
				"@type": "OfferCatalog",
				name: "Línea Tecnología",
				description:
					"Soluciones tecnológicas avanzadas para entrenamiento y operaciones de emergencia.",
				url: `${siteOrigin}/productos/flaim`,
				itemListElement: [
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Product",
							name: "FLAIM FTS - Entrenamiento VR para Bomberos",
							url: `${siteOrigin}/productos/flaim`,
						},
					},
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Product",
							name: "Cámaras térmicas",
							url: `${siteOrigin}/catalogo/Equipos`,
						},
					},
				],
			},
		],
	},
};
---

<Layout
	title="PROTON Fire & Rescue Ecuador | Equipos Bomberos, Rescate e Industria"
	description="Empresa ecuatoriana líder con +20 años en equipos de seguridad para bomberos, rescate e industria. Importadores de FLAIM VR, F-500 EA y equipos certificados. Servicio en todo Ecuador."
	keywords="equipos bomberos Ecuador, equipos rescate Ecuador, PROTON Fire Rescue, equipos seguridad industrial Ecuador, FLAIM Ecuador, F-500 Ecuador, equipos contra incendios, trajes bombero Ecuador, equipos emergencia"
	jsonLd={homePageSchema}
>
	<Menu currentPath={currentPath}/>

	<WhatsAppWidget />

	<main id="main-content" class="min-h-screen dark:bg-[#0b0b12]">
		<!-- Hero Section - Dark with firefighters background -->
		<section
			class="relative min-h-150 md:min-h-175 py-30 md:py-50 overflow-hidden"
		>
			<!-- Background Image with overlay -->
			<div class="absolute inset-0 brightness-50">
				<video
					src="/videos/home.mp4"
					class="w-full h-full object-cover"
					autoplay
					muted
					loop
					playsinline></video>
				<div class="absolute inset-0"></div>
			</div>

			<div
				class="relative z-10 max-w-360 mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 pt-30 md:pt-10 pb-20"
			>
				<div class="max-w-3xl">
					<span
						class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 text-xs md:text-sm font-semibold px-4 py-1.5 rounded-full mb-6"
						data-aos="fade-down"
						data-aos-delay="100"
					>
						<span
							class="w-2 h-2 bg-green-400 rounded-full animate-pulse"
						></span>
						+20 años protegiendo vidas en Ecuador
					</span>
					<h1
						class="text-4xl md:text-[80px] lg:text-[70px] font-[900] text-white leading-tight mb-6"
						data-aos="fade-up"
						data-aos-delay="200"
					>
						PROTON FIRE & RESCUE
					</h1>
					<p
						class="text-sm md:text-lg text-white/80 leading-relaxed mb-10 max-w-xl"
						data-aos="fade-up"
						data-aos-delay="300"
					>
						Somos una empresa ecuatoriana con más de 2 décadas de
						trayectoria en el mercado nacional. Nos especializamos
						en la importación y comercialización de equipos de
						seguridad para los sectores bomberil, de rescate e
						industrial, consolidándonos como un referente de
						confianza en el país.
					</p>
					<div
						class="flex flex-col sm:flex-row gap-4"
						data-aos="fade-up"
						data-aos-delay="400"
					>
						<CTAButton href="/productos">
							Ver Productos
							<ChevronRight />
						</CTAButton>
						<a
							href="/contactanos"
							class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm border border-white/30 text-white font-semibold px-8 py-4 rounded-full hover:bg-white/20 transition-all duration-300 hover:-translate-y-0.5"
						>
							Contáctanos
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Presencia Global Section -->
		<section
			class="flex justify-center py-40 bg-linear-to-b from-orange-50 via-white to-red-50 dark:from-[#0b0b12] dark:via-[#12121e] dark:to-[#0b0b12]"
		>
			<div class="max-w-[1420px] mx-auto px-4">
				<div class="rounded-3xl p-8 md:p-12 lg:p-16">
					<h2
						class="text-3xl md:text-4xl lg:text-[52px] font-bold text-[#2f2f3b] dark:text-white text-center mb-8"
						data-aos="fade-up"
					>
						Participación global
					</h2>
					<p
						class="text-lg text-[#6b7280] dark:text-[#9ca3b8] text-center max-w-[989px] mx-auto mb-8"
						data-aos="fade-up"
						data-aos-delay="100"
					>
						Con una visión abierta al mundo, PROTON Fire & Rescue
						participa activamente en los eventos de seguridad más
						importantes del planeta, como la FDIC en Estados Unidos
						y la INTERSCHUTZ en Alemania.
					</p>

					<div
						class="bg-[#155DFC] rounded-xl p-6 md:p-8 mb-8 max-w-[1059px] mx-auto"
						data-aos="zoom-in"
						data-aos-delay="200"
					>
						<p class="text-white text-lg text-center">
							Nuestro compromiso con la seriedad y la innovación
							nos lleva a estar presentes en las ferias
							comerciales más grandes del mundo para seguir
							contribuyendo al éxito de las organizaciones
							locales.
						</p>
					</div>

					<div
						class="text-center"
						data-aos="fade-up"
						data-aos-delay="300"
					>
						<CTAButton href="/nosotros">
							Conócenos
							<ChevronRight />
						</CTAButton>
					</div>
				</div>
			</div>
		</section>

		<!-- Líneas de Especialidad Section - Dark Background -->
		<section class="py-20 bg-[#2f2f3b] dark:bg-[#08080e]">
			<div class="max-w-[1414px] mx-auto px-4">
				<h2
					class="text-xl md:text-2xl lg:text-[52px] font-bold text-white text-center mb-12"
					data-aos="fade-up"
				>
					Nuestras líneas de especialidad
				</h2>

				<div class="grid md:grid-cols-3 gap-8">
					{
						productCategories.map((category) => (
							<a
								href={category.url}
								class="group relative overflow-hidden rounded-2xl"
								data-aos="fade-up"
							>
								<div class="relative h-[413px] overflow-hidden">
									<Image
										src={category.image}
										alt={category.name}
										class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
										loading="lazy"
										width={413}
										height={413}
									/>
									<div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/40 to-transparent" />
								</div>
								<div class="absolute bottom-0 left-0 right-0 p-6">
									<h3 class="text-2xl font-bold text-white mb-2">
										{category.name}
									</h3>
									<p class="text-zinc-200 mb-2">
										{category.description}
									</p>

									<div class="flex gap-2">
										{category.products.map((product) => {
											return (
												<div class="bg-white/20 flex items-center justify-center backdrop-blur-sm text-white text-xs font-medium px-3 py-1 rounded-full">
													{product}
												</div>
											);
										})}
									</div>
								</div>
							</a>
						))
					}

					<a
						href="/catalogo/all"
						class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-[#155DFC] to-[#7c3aed] p-6 flex flex-col justify-center items-center h-[413px]"
						data-aos="fade-up"
					>
						<div class="text-center">
							<div
								class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									class="w-8 h-8 text-white"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M4 6h16M4 10h16M4 14h16M4 18h16"
									></path>
								</svg>
							</div>
							<h3 class="text-2xl font-bold text-white mb-2">
								Ver Catálogo Completo
							</h3>
							<p class="text-white/80 mb-4">
								Explora todos nuestros productos y equipos
								disponibles
							</p>
							<span
								class="inline-flex items-center gap-2 text-white font-semibold group-hover:gap-3 transition-all duration-300"
							>
								Explorar ahora
								<svg
									xmlns="http://www.w3.org/2000/svg"
									class="w-5 h-5"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
								</svg>
							</span>
						</div>
					</a>
				</div>
			</div>
		</section>

		<!-- Servicios Adicionales Section -->
		<section class="py-20 px-8 bg-white dark:bg-[#0b0b12]">
			<div class="max-w-[1414px] mx-auto px-4">
				<h2
					class="text-3xl md:text-4xl lg:text-[57px] font-bold text-[#2f2f3b] dark:text-white text-center mb-4"
					data-aos="fade-up"
				>
					Servicios adicionales
				</h2>
				<p
					class="text-lg text-[#6b7280] dark:text-[#9ca3b8] text-center max-w-[617px] mx-auto mb-8"
					data-aos="fade-up"
					data-aos-delay="100"
				>
					Además de ofrecer productos, Proton Fire & Rescue ofrece un
					catálogo de servicios varios que te pueden interesar.
				</p>

				<div class="grid md:grid-cols-3 gap-6 py-10" data-aos="fade-up">
					<!-- Capacitación -->
					 <InfoCard title="Servicios de Capacitación" list={[`Ofrecemos capacitación
								especializada y formación de brigadas en rescate,
								primeros auxilios y trabajos de alto riesgo. `, `Somos expertos en la gestión de materiales peligrosos
								(Hazmat) y seguridad en altura, brindando soluciones
								técnicas integrales para que su industria opere bajo
								los más altos estándares de seguridad.`]} link="/servicios#capacitacion"/>
						

					<!-- Confección -->
					<InfoCard title="Servicios de Confección" list={[`Confeccionamos prendas técnicas de alta protección
							(ignífugas, dieléctricas y antidesgarro) utilizando
							insumos 100% certificados.`, `Nuestras soluciones	textiles garantizan seguridad avanzada contra
							los riesgos del entorno laboral.`]} link="/servicios#confeccion"/>
					

					<!-- Mantenimiento -->
					<InfoCard title="Servicios de Mantenimiento" list={[`Ofrecemos un servicio técnico integral y
							mantenimiento especializado para equipos de
							protección crítica.`, `Realizamos pruebas hidrostáticas, recarga de aire respirable tipo D y
							reemplazo de componentes esenciales para garantizar el correcto funcionamiento de sus equipos.`]} link="/servicios#mantenimiento"/>
					
				</div>
			</div>
		</section>

		<!-- Productos Destacados Section -->
		<section
			class="py-40 bg-gradient-to-b from-purple-50 via-white to-blue-50 dark:from-[#0b0b12] dark:via-[#12121e] dark:to-[#0b0b12]"
			id="destacados"
		>
			<div class="max-w-[1414px] mx-auto px-4">
				<h2
					class="text-3xl md:text-4xl lg:text-[52px] font-bold text-[#2f2f3b] dark:text-white text-center mb-4"
					data-aos="fade-up"
				>
					Nuestros productos destacados
				</h2>
				<p
					class="text-lg text-[#6b7280] dark:text-[#9ca3b8] text-center max-w-[692px] mx-auto mb-12"
					data-aos="fade-up"
					data-aos-delay="100"
				>
					Contamos con una variedad de productos; te presentamos los
					que más llaman la atención de nuestros clientes.
				</p>

				<Destacados client:visible />
			</div>
		</section>

		<!-- Marcas Section -->
		<section class="py-16 bg-white dark:bg-[#0b0b12]">
			<div class="max-w-[1440px] mx-auto px-4">
				<h2
					class="text-2xl md:text-3xl font-bold text-[#2f2f3b] dark:text-white text-center mb-4"
					data-aos="fade-up"
				>
					Nuestras prestigiosas marcas
				</h2>
				<p
					class="text-lg text-[#6b7280] dark:text-[#9ca3b8] text-center max-w-[632px] mx-auto mb-12"
				>
					Trabajamos con las marcas más reconocidas del mercado para
					garantizar la mejor calidad y rendimiento.
				</p>

				<BrandsCarouselData
					speed={20}
					direction="left"
					server:defer
					 imageClass='h-8 md:h-10 lg:h-12 w-auto object-contain opacity-80 hover:opacity-100 transition-all duration-300'
				>
					<div slot="fallback" class="flex items-center gap-8 overflow-hidden">
						{Array.from({ length: 6 }).map(() => (
							<div class="shrink-0 w-28 h-20 md:w-36 md:h-28 bg-gray-100 dark:bg-[#1a1a2e] rounded-md animate-pulse" />
						))}
					</div>
				</BrandsCarouselData>
			</div>
		</section>
		<hr class="my-15 mx-5 border-gray-200 dark:border-[#2a2a3e] h-px" />
		<!-- Certificaciones Section -->
		<section class="py-16 bg-white dark:bg-[#0b0b12]">
			<div class="max-w-[1440px] mx-auto px-4">
				<h2
					class="text-2xl md:text-3xl font-bold text-[#2f2f3b] dark:text-white text-center mb-4"
					data-aos="fade-up"
				>
					Certificaciones
				</h2>
				<p
					class="text-lg text-[#6b7280] dark:text-[#9ca3b8] text-center max-w-[632px] mx-auto mb-12"
				>
					Nos encargamos de distribuir productos que cumplan con
					certificaciones internacionales.
				</p>

				<InfiniteCarousel
					images={certificationImages}
					speed={30}
					direction="right"
				/>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
