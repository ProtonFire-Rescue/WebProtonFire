---
import Layout from '@/layouts/Layout.astro';
import Menu from '@/components/page/Menu.astro';
import Footer from '@/components/page/Footer.astro';

const currentPath = Astro.url.pathname;

const characteristics =  [
  'Entrenamiento virtual ideal para bomberos.',
  'Escenarios 3D hiperrealistas.',
  'Entorno seguro y sin riesgos.',
  'Experiencia real con calor y respiración.',
  'Menos costoso que una práctica real.',
  'Proceso de aprendizaje y retroalimentación.'
]

const princial_characteristics = [
  {
    title: 'Entrenamiento inmersivo',
    description: 'Utiliza visores de RV, mangueras y extintores reales, ofreciendo experiencias de entrenamiento que se sienten reales.'
  },
  {
    title: 'FLAIM Trainer',
    description: 'Sistema integral que recrea incendios con alta fidelidad, permitiendo a los bomberos sentir el calor radiante, la fuerza de la manguera y gestionar su propio suministro de aire (SCBA).'
  },
  {
    title: 'FLAIM Extinguisher',
    description: 'Solución específica para entrenar en el uso correcto de extintores contra diversos tipos de fuego en entornos seguros.'
  },
  {
    title: 'Datos y Analítica',
    description: 'Incluye FLAIM Capture, una plataforma para registrar el desempeño, analizar habilidades y mejorar la toma de decisiones basada en datos.'
  },
  {
    title: 'Aplicaciones',
    description: 'Utilizado por equipos de emergencia, defensa y sectores industriales para formación inicial y continua.'
  }
]

// Structured Data para FLAIM
const flaimProductSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "FLAIM FTS - Sistema de Formación de Bomberos",
  "description": "FLAIM Trainer System - Tecnología de realidad virtual para entrenamiento de bomberos. Sistema de formación inmersivo y seguro con escenarios 3D hiperrealistas.",
  "brand": {
    "@type": "Brand",
    "name": "FLAIM"
  },
  "image": [
    "https://www.protonfire.com/flaim/flaim_body.jpg",
    "https://www.protonfire.com/flaim/flaim_demo1.jpg",
    "https://www.protonfire.com/flaim/flaim_demo2.jpg",
    "https://www.protonfire.com/flaim/flaim_demo3.webp",
    "https://www.protonfire.com/flaim/flaim_complete.jpg"
  ],
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": {
      "@type": "Organization",
      "name": "PROTON Fire & Rescue"
    }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "47"
  },
  "category": "Equipos de Entrenamiento para Bomberos",
  "manufacturer": {
    "@type": "Organization",
    "name": "FLAIM Systems"
  }
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://www.protonfire.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Productos",
      "item": "https://www.protonfire.com/productos"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "FLAIM FTS",
      "item": "https://www.protonfire.com/productos/flaim"
    }
  ]
};

---

<Layout
  title="FLAIM FTS - Sistema de Formación de Bomberos VR | PROTON Ecuador"
  description="FLAIM Trainer System - Tecnología de realidad virtual para entrenamiento de bomberos en Ecuador. Sistema de formación inmersivo, seguro y efectivo con escenarios 3D hiperrealistas. Reduce costos y riesgos."
  url="https://www.protonfire.com/productos/flaim"
  image="https://www.protonfire.com/flaim/flaim_body.jpg"
  type="product"
  keywords="FLAIM FTS, entrenamiento bomberos VR, realidad virtual bomberos, simulador incendios, FLAIM Ecuador, capacitación bomberos, entrenamiento virtual incendios, FLAIM Trainer, equipos bomberos Ecuador"
  jsonLd={[flaimProductSchema, breadcrumbSchema]}
>
  <Menu currentPath={currentPath} />

  <main class="bg-white">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-linear-to-br from-purple-50 via-white to-blue-50">
      <div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 py-20">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Left Content -->
          <div class="space-y-6">
            <h1 class="text-5xl lg:text-6xl font-bold text-[#2f2f3b] leading-tight" data-aos="fade-up" data-aos-delay="100">
              FLAIM FTS
            </h1>
            <p class="text-lg text-gray-600 leading-relaxed max-w-xl" data-aos="fade-up" data-aos-delay="200">
El sistema que proporciona a los bomberos las habilidades esenciales para mejorar la calidad del entrenamiento contra incendios en vivo y mejorar el conocimiento de la situación durante la extinción de incendios en la vida real.            </p>
            <a href="#comenzar" data-aos="fade-up" data-aos-delay="300" class="bg-[#504aff] text-white px-8 py-4 rounded-full font-semibold hover:bg-[#3f3bcc] transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1">
              Ver más
            </a>
          </div>

          <!-- Right Image -->
          <div class="relative flex justify-center">
            <div class="relative md:w-130 bg-white rounded-3xl shadow-2xl p-8 transform hover:scale-105 transition-transform duration-500" data-aos="fade-left">
              <img
                src="/flaim/flaim_body.jpg"
                alt="FLAIM FTS Training System"
                class="w-full h-auto object-contain"
                loading="eager"
              />
            </div>
            <!-- Decorative elements -->
            <div class="absolute -top-6 -right-6 w-32 h-32 bg-purple-200 rounded-full blur-3xl opacity-50"></div>
            <div class="absolute -bottom-6 -left-6 w-40 h-40 bg-blue-200 rounded-full blur-3xl opacity-50"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- FLAIM Trainer System Section -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Image -->
          <div class="order-2 lg:order-1 flex justify-center">
            <div class="relative rounded-3xl overflow-hidden shadow-xl md:w-120" data-aos="fade-right">
              <img
                src="/flaim/flaim_demo2.jpg"
                alt="FLAIM Trainer System Demo"
                class="w-full h-auto object-cover"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Content -->
          <div class="order-1 lg:order-2 space-y-6">
            <h2 class="text-4xl lg:text-5xl font-bold text-[#2f2f3b]" data-aos="fade-left">
              FLAIM Trainer System
            </h2>
            <p class="text-lg text-gray-600 leading-relaxed">
Capacitación y entrenamiento mediante realidad virtual 
ahora en Ecuador, ofrece:             </p>
            <ul class="space-y-4">
              {
                characteristics.map((char) => (
                  <li class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-[#504aff] flex items-center justify-center shrink-0 mt-1">
                      <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </div>
                    <span class="text-gray-700">{char}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Características Principales -->
    <section class="py-20 bg-white">
      <div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row gap-8">
        <section class="flex flex-col w-full lg:w-1/2 lg:mx-20 gap-8">
          <div class="text-start">
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#2f2f3b] mb-4" data-aos="fade-up">
              Características principales:
            </h2>
          </div>
          {
            princial_characteristics.map((char) => (
              <div class="space-y-4" data-aos="fade-up">
                <h3 class="text-xl md:text-2xl font-bold text-[#2f2f3b]">{char.title}</h3>
                <p class="text-gray-600 leading-relaxed text-sm md:text-base">
                  {char.description}
                </p>
              </div>
            ))
          }
        </section>

        <section class="flex flex-col w-full lg:w-1/2 gap-6 md:gap-8">
          <!-- Feature 2 -->
          <div class="bg-gray-50 rounded-2xl p-4 md:p-6" data-aos="fade-left" data-aos-delay="100">
            <img
              src="/flaim/flaim_demo3.webp"
              alt="VR Training"
              class="w-full h-48 sm:h-64 md:h-80 object-cover rounded-xl mb-4"
              loading="lazy"
            />
          </div>

          <!-- Feature 3 -->
          <div class="bg-gray-50 rounded-2xl p-4 md:p-6" data-aos="fade-left" data-aos-delay="200">
            <img
              src="/flaim/flaim_complete.jpg"
              alt="Training Action"
              class="w-full h-36 sm:h-40 md:h-48 object-cover rounded-xl mb-4"
              loading="lazy"
            />
          </div>

          <!-- Feature 6 -->
          <div class="bg-gray-50 rounded-2xl p-4 md:p-6" data-aos="fade-left" data-aos-delay="300">
            <img
              src="/flaim/flaim_demo1.jpg"
              alt="FLAIM Demo"
              class="w-full h-48 sm:h-64 md:h-80 object-cover rounded-xl mb-4"
              loading="lazy"
            />
          </div>
        </section>
      </div>
    </section>

    <!-- Sistema de Formación FTR -->
    <!-- <section class="py-20 bg-gradient-to-br from-purple-50 via-white to-blue-50">
      <div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8">
