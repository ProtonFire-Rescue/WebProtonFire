---
import Layout from '@/layouts/Layout.astro';
import Menu from '@/components/page/Menu.astro';
import Footer from '@/components/page/Footer.astro';
import CTAButton from '@/components/ui/CTAButton.astro';
import { Image } from 'astro:assets';

const currentPath = Astro.url.pathname;
const siteOrigin = Astro.url.origin;

const characteristics =  [
  'Entrenamiento virtual ideal para bomberos.',
  'Escenarios 3D hiperrealistas.',
  'Entorno seguro y sin riesgos.',
  'Experiencia real con calor y respiración.',
  'Menos costoso que una práctica real.',
  'Proceso de aprendizaje y retroalimentación.'
]

const principal_characteristics = [
  {
    title: 'Entrenamiento inmersivo',
    description: 'Utiliza visores de RV, mangueras y extintores reales, ofreciendo experiencias de entrenamiento que se sienten reales.'
  },
  {
    title: 'FLAIM Trainer',
    description: 'Sistema integral que recrea incendios con alta fidelidad, permitiendo a los bomberos sentir el calor radiante, la fuerza de la manguera y gestionar su propio suministro de aire (SCBA).'
  },
  {
    title: 'FLAIM Extinguisher',
    description: 'Solución específica para entrenar en el uso correcto de extintores contra diversos tipos de fuego en entornos seguros.'
  },
  {
    title: 'Datos y Analítica',
    description: 'Incluye FLAIM Capture, una plataforma para registrar el desempeño, analizar habilidades y mejorar la toma de decisiones basada en datos.'
  },
  {
    title: 'Aplicaciones',
    description: 'Utilizado por equipos de emergencia, defensa y sectores industriales para formación inicial y continua.'
  }
]

// Structured Data para FLAIM
const flaimProductSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "FLAIM FTS - Sistema de Formación de Bomberos con Realidad Virtual",
  "description": "FLAIM Trainer System - Tecnología de realidad virtual para entrenamiento de bomberos en Ecuador. Sistema de formación inmersivo y seguro con escenarios 3D hiperrealistas, calor radiante simulado, gestión de SCBA y analítica de rendimiento en tiempo real.",
  "url": `${siteOrigin}/productos/flaim`,
  "sku": "FLAIM-FTS",
  "brand": {
    "@type": "Brand",
    "name": "FLAIM Systems"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "FLAIM Systems",
    "url": "https://flaimsystems.com/"
  },
  "image": [
    `${siteOrigin}/flaim/flaim_body.webp`,
    `${siteOrigin}/flaim/flaim_demo1.webp`,
    `${siteOrigin}/flaim/flaim_demo2.webp`,
    `${siteOrigin}/flaim/flaim_demo3.webp`,
    `${siteOrigin}/flaim/flaim_complete.webp`
  ],
  "offers": {
    "@type": "Offer",
    "url": `${siteOrigin}/productos/flaim`,
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": { "@id": `${siteOrigin}/#organization` },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "EC" },
      "deliveryTime": { "@type": "ShippingDeliveryTime", "handlingTime": { "@type": "QuantitativeValue", "minValue": 5, "maxValue": 30, "unitCode": "DAY" } }
    }
  },
  "countryOfOrigin": { "@type": "Country", "name": "Australia" },
  "category": "Equipos de Entrenamiento para Bomberos",
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "Tecnología", "value": "Realidad Virtual (VR)" },
    { "@type": "PropertyValue", "name": "Tipo de Entrenamiento", "value": "Extinción de incendios, uso de extintores, SCBA" },
    { "@type": "PropertyValue", "name": "Escenarios", "value": "3D hiperrealistas con calor radiante" },
    { "@type": "PropertyValue", "name": "Analítica", "value": "FLAIM Capture - plataforma de datos de rendimiento" },
    { "@type": "PropertyValue", "name": "Aplicaciones", "value": "Bomberos, defensa, industria" }
  ]
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteOrigin },
    { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteOrigin}/productos` },
    { "@type": "ListItem", "position": 3, "name": "FLAIM FTS", "item": `${siteOrigin}/productos/flaim` }
  ]
};

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué es el sistema FLAIM FTS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "FLAIM FTS (Fire Training System) es un sistema de entrenamiento basado en realidad virtual que permite a los bomberos practicar la extinción de incendios en escenarios 3D hiperrealistas con calor radiante simulado, sin los riesgos de un entrenamiento con fuego real."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué incluye el sistema FLAIM?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El sistema incluye FLAIM Trainer (manguera con visor VR y calor radiante), FLAIM Extinguisher (entrenamiento con extintores) y FLAIM Capture (plataforma de analítica para registrar el desempeño y mejorar habilidades)."
      }
    },
    {
      "@type": "Question",
      "name": "¿Es más económico que el entrenamiento con fuego real?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, FLAIM reduce significativamente los costos de entrenamiento al eliminar la necesidad de combustible, infraestructura de quema, y riesgos de lesiones. Además, permite repetir escenarios ilimitadamente sin costo adicional."
      }
    },
    {
      "@type": "Question",
      "name": "¿Está disponible FLAIM en Ecuador?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, PROTON Fire & Rescue es distribuidor autorizado de FLAIM Systems en Ecuador. Ofrecemos el sistema completo con instalación, capacitación y soporte técnico local."
      }
    }
  ]
};

---

<Layout
  title="FLAIM FTS - Sistema de Formación de Bomberos VR | PROTON Fire & Rescue Ecuador"
  description="FLAIM Trainer System - Tecnología de realidad virtual para entrenamiento de bomberos en Ecuador. Sistema de formación inmersivo, seguro y efectivo con escenarios 3D hiperrealistas. Reduce costos y riesgos."
  image="/flaim/flaim_body.webp"
  type="product"
  keywords="FLAIM FTS, entrenamiento bomberos VR, realidad virtual bomberos, simulador incendios, FLAIM Ecuador, capacitación bomberos, entrenamiento virtual incendios, FLAIM Trainer, equipos bomberos Ecuador"
  jsonLd={[flaimProductSchema, breadcrumbSchema, faqSchema]}
  productBrand="FLAIM Systems"
>
  <Menu currentPath={currentPath} />

  <main class="bg-white dark:bg-[#0b0b12]">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-linear-to-br from-purple-50 via-white to-blue-50 dark:from-[#0b0b12] dark:via-[#12121e] dark:to-[#0b0b12]">
      <div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 py-20">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Left Content -->
          <div class="space-y-6">
            <h1 class="text-5xl lg:text-6xl font-bold text-[#2f2f3b] dark:text-white leading-tight" data-aos="fade-up" data-aos-delay="100">
              FLAIM FTS
            </h1>
            <p class="text-lg text-gray-600 dark:text-[#9ca3b8] leading-relaxed max-w-xl" data-aos="fade-up" data-aos-delay="200">
El sistema que proporciona a los bomberos las habilidades esenciales para mejorar la calidad del entrenamiento contra incendios en vivo y mejorar el conocimiento de la situación durante la extinción de incendios en la vida real.            </p>
            <div data-aos="fade-up" data-aos-delay="300">
              <CTAButton href="#comenzar" >
                Ver más
                </CTAButton>
            </div>
          </div>

          <!-- Right Image -->
          <div class="relative flex justify-center" data-aos="fade-left">
            <div class="relative md:w-130 bg-white dark:bg-[#1a1a2e] rounded-3xl shadow-2xl dark:shadow-black/30 p-8 transform hover:scale-105 transition-transform duration-500" >
              <Image
                src="/flaim/flaim_body.webp"
                alt="Equipo FLAIM FTS Training System para el entrenamiento en realidad virtual"
                class="w-full h-auto object-contain"
                loading="eager"
                width={480}
                height={320}
              />
            </div>
            <!-- Decorative elements -->
            <div class="absolute -top-6 -right-6 w-32 h-32 bg-purple-200 rounded-full blur-3xl opacity-50"></div>
            <div class="absolute -bottom-6 -left-6 w-40 h-40 bg-blue-200 rounded-full blur-3xl opacity-50"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- FLAIM Trainer System Section -->
    <section class="py-20 bg-gray-50 dark:bg-[#12121e]">
      <div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Image -->
          <div class="order-2 lg:order-1 flex justify-center" data-aos="fade-right">
            <div class="relative rounded-3xl overflow-hidden shadow-xl md:w-120" >
              <Image
                src="/flaim/flaim_demo2.webp"
                alt="Equipo FLAIM Trainer System Demo"
                class="w-full h-auto object-cover"
                loading="lazy"
                width={480}
                height={320}
              />
            </div>
          </div>

          <!-- Content -->
          <div class="order-1 lg:order-2 space-y-6">
            <h2 class="text-4xl lg:text-5xl font-bold text-[#2f2f3b] dark:text-white" data-aos="fade-left">
              FLAIM Trainer System
            </h2>
            <p class="text-lg text-gray-600 dark:text-[#9ca3b8] leading-relaxed">
Capacitación y entrenamiento mediante realidad virtual 
ahora en Ecuador, ofrece:             </p>
            <ul class="space-y-4">
              {
                characteristics.map((char) => (
                  <li class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-[#504aff] flex items-center justify-center shrink-0 mt-1">
                      <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </div>
                    <span class="text-gray-700 dark:text-[#c8c8d8]">{char}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Características Principales -->
    <section class="py-20 bg-white dark:bg-[#0b0b12]">
      <div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row gap-8">
        <section class="flex flex-col w-full lg:w-1/2 lg:mx-20 gap-8">
          <div class="text-start">
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#2f2f3b] dark:text-white mb-4" data-aos="fade-up">
              Características principales:
            </h2>
          </div>
          {
            principal_characteristics.map((char) => (
              <div class="space-y-4" data-aos="fade-up">
                <div class="flex items-center gap-3">
                  <div class="w-6 h-6 rounded-full bg-[#504aff] flex items-center justify-center shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <h3 class="text-xl md:text-2xl font-bold text-[#2f2f3b] dark:text-white">{char.title}</h3>
                </div>
                <p class="text-gray-600 dark:text-[#9ca3b8] leading-relaxed text-sm md:text-base">
                  {char.description}
                </p>
              </div>
            ))
          }
        </section>

        <section class="flex flex-col w-full lg:w-1/2 gap-6 md:gap-8">
          <!-- Feature 2 -->
          <div class="bg-gray-50 dark:bg-[#1a1a2e] rounded-2xl p-4 md:p-6" data-aos="fade-left" data-aos-delay="100">
            <Image
              src="/flaim/flaim_demo3.webp"
              alt="Equipo VR Training para el entrenamiento en entornos virtuales bomberiles"
              class="w-full h-48 sm:h-64 md:h-80 object-cover rounded-xl mb-4"
              loading="lazy"
              width={480}
              height={320}
            />
          </div>

          <!-- Feature 3 -->
          <div class="bg-gray-50 dark:bg-[#1a1a2e] rounded-2xl p-4 md:p-6" data-aos="fade-left" data-aos-delay="200">
            <Image
              src="/flaim/flaim_complete.webp"
              alt="Equipo Flaim FTS en acción"
              class="w-full h-36 sm:h-40 md:h-48 object-cover rounded-xl mb-4"
              loading="lazy"
              width={480}
              height={320}
            />
          </div>

          <!-- Feature 6 -->
          <div class="bg-gray-50 dark:bg-[#1a1a2e] rounded-2xl p-4 md:p-6" data-aos="fade-left" data-aos-delay="300">
            <Image
              src="/flaim/flaim_demo1.webp"
              alt="Demostración del equipo Flaim FTS"
              class="w-full h-48 sm:h-64 md:h-80 object-cover rounded-xl mb-4"
              loading="lazy"
              width={480}
              height={320}
            />
          </div>
        </section>
      </div>
    </section>

    <!-- Sistema de Formación FTR -->
    <!-- <section class="py-20 bg-gradient-to-br from-purple-50 via-white to-blue-50">
      <div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8">
