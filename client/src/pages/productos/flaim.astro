              <img
                src="/flaim/flaim_body.jpg"
                alt="FLAIM FTS Sistema"
                class="w-full h-auto object-contain"
                loading="lazy"
              />
            </div>
          </div>

          <div class="space-y-6">
            <h2 class="text-4xl lg:text-5xl font-bold text-[#2f2f3b]">
              FLAIM FTS<br />
              Sistema de formación<br />
              de bomberos FTR
