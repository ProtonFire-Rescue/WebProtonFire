    <!-- CTA Section -->
    <section id="comenzar" class="py-60 bg-linear-to-r from-purple-50 via-white to-blue-50 dark:from-[#0b0b12] dark:via-[#12121e] dark:to-[#0b0b12]">
      <div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl lg:text-5xl font-bold text-[#2f2f3b] dark:text-white mb-6" data-aos="fade-up">
          ¿Listo para revolucionar tu entrenamiento?
        </h2>
        <p class="text-xl text-gray-600 dark:text-[#9ca3b8] mb-8 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
          Descubre cómo FLAIM FTS puede transformar la capacitación de tu equipo de bomberos
