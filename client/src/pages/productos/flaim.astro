        <div data-aos="fade-up" data-aos-delay="200">
          <CTAButton
            href="https://wa.me/593992526658?text=Me%20interesar%C3%ADa%20obtener%20informaci%C3%B3n%20acerca%20del%20producto%20Flaim%20FTS"
            target="_blank"
            size="lg"
          >
            Solicitar Demo
          </CTAButton>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
