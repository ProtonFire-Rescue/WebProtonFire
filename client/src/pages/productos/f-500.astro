---
import Layout from '@/layouts/Layout.astro';
import Menu from '@/components/page/Menu.astro';
import Footer from '@/components/page/Footer.astro';

const currentPath = Astro.url.pathname;

const fireTypes = [
  { class: 'A', description: 'Sólidos combustibles (cartón, papel, etc.)' },
  { class: 'B', description: 'Líquidos inflamables (hidrocarburos, pintura, etc.)' },
  { class: 'C', description: 'Eléctricos (transformadores desenergizados)' },
  { class: 'D', description: 'Metales combustibles (magnesio, aluminio, litio, etc.)' },
  { class: 'K', description: 'Aceites y grasas (en cocinas, calderos, etc.)' }
];

const howItWorks = [
  'Enfría rápidamente el fuego, reduciendo la temperatura del combustible.',
  'Encapsula el combustible, evitando que el oxígeno alimente el fuego.',
  'Reduce la tensión superficial del agua, permitiendo una mayor penetración.',
  'Forma una barrera protectora que previene la re-ignición.',
  'Biodegradable y seguro para el medio ambiente.',
  'No deja residuos pegajosos ni corrosivos.'
];

const specifications = [
  { title: 'Capacidad de extinción para múltiples clases de fuego', description: 'Efectivo contra fuegos de clase A, B, C, D y K, ofreciendo una solución versátil.' },
  { title: 'Fórmula biodegradable y no tóxica', description: 'Seguro para el medio ambiente, humanos y animales, sin efectos nocivos.' },
  { title: 'Reduce el tiempo de extinción significativamente', description: 'Actúa más rápido que el agua sola, controlando incendios en menos tiempo.' },
  { title: 'Disminuye el consumo de agua hasta en un 50%', description: 'Optimiza el uso de recursos hídricos durante la extinción.' },
  { title: 'Previene la re-ignición del fuego', description: 'Crea una barrera protectora que evita que el fuego vuelva a encenderse.' },
  { title: 'No corrosivo para equipos ni superficies', description: 'Protege la integridad de equipos y estructuras durante su aplicación.' },
  { title: 'Versátil y fácil de aplicar', description: 'Compatible con equipos estándar de extinción, sin necesidad de modificaciones.' },
  { title: 'No deja residuos ni manchas', description: 'Limpieza sencilla después de su uso, sin residuos pegajosos.' }
];

// Structured Data para F-500
const f500ProductSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "F-500 EA - Agente Encapsulador",
  "description": "F-500 EA es un agente encapsulador de última generación para combatir fuegos de clase A, B, C, D y K. Biodegradable, no tóxico y altamente eficaz. Reduce el tiempo de extinción y el consumo de agua.",
  "brand": {
    "@type": "Brand",
    "name": "F-500"
  },
  "image": [
    "https://protonfire.com/f-500/product_present.webp",
    "https://protonfire.com/f-500/fire_types.webp",
    "https://protonfire.com/f-500/cient_type1.webp",
    "https://protonfire.com/f-500/cient_type2.webp",
    "https://protonfire.com/f-500/cient_type3.webp"
  ],
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "seller": {
      "@type": "Organization",
      "name": "PROTON Fire & Rescue"
    }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "62"
  },
  "category": "Agentes Extintores",
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Tipo",
      "value": "Agente Encapsulador"
    },
    {
      "@type": "PropertyValue",
      "name": "Clases de Fuego",
      "value": "A, B, C, D, K"
    },
    {
      "@type": "PropertyValue",
      "name": "Biodegradable",
      "value": "Sí"
    }
  ]
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://protonfire.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Productos",
      "item": "https://protonfire.com/productos"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "F-500 EA",
      "item": "https://protonfire.com/productos/f-500"
    }
  ]
};

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué tipos de fuego controla F-500 EA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "F-500 EA controla fuegos de Clase A (sólidos combustibles), Clase B (líquidos inflamables), Clase C (eléctricos), Clase D (metales combustibles) y Clase K (aceites y grasas)."
      }
    },
    {
      "@type": "Question",
      "name": "¿Es F-500 EA seguro para el medio ambiente?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, F-500 EA es completamente biodegradable y no tóxico, seguro para el medio ambiente, humanos y animales."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cómo actúa F-500 EA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "F-500 EA actúa enfriando rápidamente el fuego, encapsulando el combustible, reduciendo la tensión superficial del agua y formando una barrera protectora que previene la re-ignición."
      }
    }
  ]
};
---

<Layout 
	title="F-500 EA - Agente Encapsulador Extintor | PROTON Ecuador"
	description="F-500 EA es un agente encapsulador de última generación para combatir fuegos clase A, B, C, D y K en Ecuador. Biodegradable, no tóxico, reduce tiempo de extinción y consumo de agua hasta 50%. Solución eficaz contra incendios."
	url="https://protonfire.com/productos/f-500"
	image="https://protonfire.com/f-500/product_present.webp"
	type="product"
	keywords="F-500 EA, agente encapsulador, extintor incendios, F-500 Ecuador, agente extintor biodegradable, extinción fuegos clase A B C D K, agente extintor no tóxico, F-500 encapsulator, equipos contra incendios Ecuador"
	jsonLd={[f500ProductSchema, breadcrumbSchema, faqSchema]}
>
	<Menu currentPath={currentPath} />
	
	<main class="bg-white">
		<!-- Hero Section -->
		<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-red-50 via-white to-orange-50">
			<div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 py-20">
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<!-- Left Content -->
					<div class="space-y-6">
						<h1 class="text-5xl lg:text-6xl font-bold text-[#2f2f3b] leading-tight" data-aos="fade-up" data-aos-delay="100">
							F-500 EA<br />
							<span class="text-3xl lg:text-4xl text-gray-600">(Encapsulator Agent)</span>
						</h1>
						<p class="text-lg text-gray-600 leading-relaxed max-w-xl" data-aos="fade-up" data-aos-delay="200">
							Un agente encapsulador de última generación que ofrece una solución versátil y segura para combatir fuegos de diversas clases. Su fórmula biodegradable y no tóxica lo hace ideal para proteger tanto a los equipos de emergencia como al medio ambiente.
						</p>
						<a href="#comenzar" data-aos="fade-up" data-aos-delay="300" class="inline-block bg-[#504aff] text-white px-8 py-4 rounded-full font-semibold hover:bg-[#3f3bcc] transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1">
							Ver más
						</a>
					</div>

					<!-- Right Image -->
					<div class="relative flex justify-center">
						<div class="relative md:w-130 bg-white rounded-3xl shadow-2xl p-8 transform hover:scale-105 transition-transform duration-500" data-aos="fade-left">
							<img
								src="/f-500/product_present.webp"
								alt="F-500 EA Encapsulator Agent"
								class="w-full h-auto object-contain"
								loading="eager"
							/>
						</div>
						<!-- Decorative elements -->
						<div class="absolute -top-6 -right-6 w-32 h-32 bg-red-200 rounded-full blur-3xl opacity-50"></div>
						<div class="absolute -bottom-6 -left-6 w-40 h-40 bg-orange-200 rounded-full blur-3xl opacity-50"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- Fire Types Section -->
		<section class="py-20">
			<div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<!-- Image -->
					<div class="order-2 lg:order-1 flex justify-center">
						<div class="relative rounded-3xl overflow-hidden shadow-xl md:w-120" data-aos="fade-right">
							<img
								src="/f-500/fire_types.webp"
								alt="Tipos de fuego que controla F-500"
								class="w-full h-auto object-cover"
								loading="lazy"
							/>
						</div>
					</div>

					<!-- Content -->
					<div class="order-1 lg:order-2 space-y-6">
						<h2 class="text-4xl lg:text-5xl font-bold text-[#2f2f3b]" data-aos="fade-left">
							¿Qué tipos de fuego controla?
						</h2>
						<p class="text-lg text-gray-600 leading-relaxed">
							Controla diferentes tipos de fuegos, tales como:
						</p>
						<ul class="space-y-4">
							{fireTypes.map((type) => (
								<li class="flex items-start gap-3">
									<div class="w-6 h-6 rounded-full bg-[#504aff] flex items-center justify-center shrink-0 mt-1">
										<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
										</svg>
									</div>
									<span class="text-gray-700"><strong>Clase {type.class}:</strong> {type.description}</span>
								</li>
							))}
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- How It Works Section -->
		<section class="py-12 md:py-20 bg-white">
			<div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
					<!-- Content -->
					<div class="space-y-6 md:mx-20 lg:mx-0 xl:mx-20">
						<h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#2f2f3b]" data-aos="fade-up">
							¿Cómo actúa?
						</h2>
						<p class="text-base md:text-lg text-gray-600 leading-relaxed">
							El F500 al ser rociado sobre el fuego mediante un eductor común, y al tener menor tensión superficial que el agua, penetra y encapsula las moléculas del mismo, rompiendo la reacción en cadena con un abrupto descenso de la temperatura en segundos. 
						</p>
						<p class="text-base md:text-lg font-bold text-[#2f2f3b] my-4">
							Entre sus principales características tenemos:
						</p>
						<ul class="space-y-3 md:space-y-4">
							{howItWorks.map((item) => (
								<li class="flex items-start gap-3">
									<div class="w-3 h-3 md:w-6 md:h-6 rounded-full bg-[#504aff] flex items-center justify-center shrink-0 mt-1">
									</div>
									<p class="text-sm md:text-base text-gray-700">{item}</p>
								</li>
							))}
						</ul>
					</div>

					<!-- Images Grid -->
					<div class="flex flex-col items-center gap-6 md:gap-10 mt-8 lg:mt-0">
						<div class="bg-gray-50 rounded-2xl p-4 md:p-6 w-full max-w-xs sm:max-w-sm md:max-w-md lg:w-full xl:w-120" data-aos="fade-left" data-aos-delay="100">
							<img
								src="/f-500/cient_type1.webp"
								alt="F-500 en acción"
								class="w-full h-full object-cover rounded-xl"
								loading="lazy"
							/>
						</div>
						<div class="bg-gray-50 rounded-2xl p-4 md:p-6 w-full max-w-xs sm:max-w-sm md:max-w-md lg:w-full xl:w-120" data-aos="fade-left" data-aos-delay="200">
							<img
								src="/f-500/cient_type2.webp"
								alt="Aplicación de F-500"
								class="w-full h-full object-cover rounded-xl"
								loading="lazy"
							/>
						</div>
						<div class="bg-gray-50 rounded-2xl p-4 md:p-6 w-full max-w-xs sm:max-w-sm md:max-w-md lg:w-full xl:w-120" data-aos="fade-left" data-aos-delay="300">
							<img
								src="/f-500/cient_type3.webp"
								alt="Aplicación de F-500"
								class="w-full h-full object-cover rounded-xl"
								loading="lazy"
							/>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Specifications Section -->
		<!-- <section class="py-20 bg-gradient-to-br from-red-50 via-white to-orange-50">
			<div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div class="relative">
						<div class="relative bg-white rounded-3xl shadow-2xl p-8">
							<img
								src="/f-500/product_present.webp"
								alt="F-500 EA Sistema"
								class="w-full h-auto object-contain"
								loading="lazy"
							/>
						</div>
					</div>

					<div class="space-y-6">
						<h2 class="text-4xl lg:text-5xl font-bold text-[#2f2f3b]">
							F-500 EA<br />
							(Encapsulator Agent)
						</h2>
						<p class="text-sm text-gray-500 uppercase tracking-wide">
							Características principales
						</p>

						<div class="space-y-4">
							{specifications.map((spec, index) => (
								<div class="flex items-start gap-3">
									<div class={`w-3 h-3 rounded-full flex-shrink-0 mt-2 ${
										index % 6 === 0 ? 'bg-red-500' :
										index % 6 === 1 ? 'bg-orange-500' :
										index % 6 === 2 ? 'bg-yellow-500' :
										index % 6 === 3 ? 'bg-green-500' :
										index % 6 === 4 ? 'bg-blue-500' :
										'bg-purple-500'
									}`}></div>
									<div>
										<h4 class="font-semibold text-[#2f2f3b] mb-1">{spec.title}</h4>
										<p class="text-gray-600 text-sm">{spec.description}</p>
									</div>
								</div>
							))}
						</div>

						<button class="bg-[#504aff] text-white px-8 py-4 rounded-full font-semibold hover:bg-[#3f3bcc] transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1 mt-8">
							Conoce Más
						</button>
					</div>
				</div>
			</div>
		</section> -->

		<!-- CTA Section -->
		<section id="comenzar" class="py-60 bg-gradient-to-r from-red-50 via-white to-orange-50">
			<div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h2 class="text-4xl lg:text-5xl font-bold mb-6" data-aos="fade-up">
					¿Interesado en F-500 EA?
				</h2>
				<p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
					Descubre cómo F-500 EA puede transformar la seguridad contra incendios en tus instalaciones
				</p>
				<a
					href="https://wa.me/593982487322?text=Hola, me interesa obtener información acerca del F-500 EA"
					target="_blank"
					data-aos="fade-up" data-aos-delay="200"
					class="inline-block bg-[#504aff] text-white px-10 py-5 rounded-full font-semibold text-lg hover:bg-[#3f3bcc] transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1"
				>
					Solicitar Información
				</a>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>
