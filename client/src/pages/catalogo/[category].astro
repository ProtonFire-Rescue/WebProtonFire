---
import Layout from '@/layouts/Layout.astro'
import Menu from '@/components/page/Menu.astro'
import Footer from '@/components/page/Footer.astro'
import CatalogData from '@/components/CatalogData.astro'

const currentPath = Astro.url.pathname
const siteOrigin = Astro.url.origin

const { category } = Astro.params
const categoryLabel = category === 'all' ? 'Todos los Productos' : decodeURIComponent(category ?? 'all')

const catalogJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Catálogo de Productos - PROTON Fire & Rescue',
    description:
      'Explora nuestro catálogo completo de equipos de seguridad para bomberos, rescate e industria. Filtra por categoría, marca y precio.',
    url: `${siteOrigin}/catalogo/${category}`,
    image: `${siteOrigin}/images/og/og_home.webp`,
    isPartOf: {
      '@type': 'WebSite',
      name: 'PROTON Fire & Rescue Ecuador',
      url: siteOrigin
    },
    provider: {
      '@type': 'Organization',
      name: 'PROTON Fire & Rescue',
      url: siteOrigin
    }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteOrigin },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Catálogo',
        item: `${siteOrigin}/catalogo/all`
      },
      ...(category && category !== 'all'
        ? [
            {
              '@type': 'ListItem',
              position: 3,
              name: categoryLabel,
              item: `${siteOrigin}/catalogo/${category}`
            }
          ]
        : [])
    ]
  }
]
---

<Layout
  title='Catálogo de Equipos de Bomberos y Rescate | PROTON Fire & Rescue Ecuador'
  description='Explora nuestro catálogo completo de equipos de seguridad. Filtra por categoría, marca y precio.'
  keywords='catálogo equipos bomberos, filtrar productos seguridad, equipos contra incendios Ecuador, trajes bombero catálogo'
  jsonLd={catalogJsonLd}
>
  <Menu currentPath={currentPath} />

  <main>
    <!-- Header Section -->
    <section class='py-16 bg-white'>
      <div class='max-w-360 mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mt-16'>
          <h1
            class='text-3xl md:text-4xl lg:text-[40px] font-bold text-[#2f2f3b] mb-3'
          >
            Busca el producto de tu interés
          </h1>
          <p class='text-gray-500 max-w-xl mx-auto'>
            Explora nuestro catálogo completo y encuentra el equipo perfecto
            para tus necesidades
          </p>
        </div>
      </div>
    </section>

    <!-- Product Catalog Section -->
    <section class='pb-20 bg-white'>
      <div class='max-w-360 mx-auto px-4 sm:px-6 lg:px-8'>
        <CatalogData server:defer category={category}>
          <div
            slot='fallback'
            class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6'
          >
            {
              Array.from({ length: 8 }).map((_, i) => (
                <div
                  key={i}
                  class='bg-white rounded-2xl border border-gray-100 overflow-hidden'
                >
                  <div class='relative aspect-3/4 overflow-hidden bg-gray-50 p-4'>
                    <div class='w-full h-full bg-gray-200 animate-pulse rounded-xl' />
                  </div>
                  <div class='p-4 space-y-3'>
                    <div class='h-4 bg-gray-200 animate-pulse rounded w-3/4' />
                    <div class='h-3 bg-gray-200 animate-pulse rounded w-1/2' />
                    <div class='h-3 bg-gray-200 animate-pulse rounded w-2/3' />
                    <div class='h-9 bg-gray-200 animate-pulse rounded' />
                  </div>
                </div>
              ))
            }
          </div>
        </CatalogData>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
