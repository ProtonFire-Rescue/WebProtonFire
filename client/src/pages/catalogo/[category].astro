---
import Layout from '@/layouts/Layout.astro'
import Menu from '@/components/page/Menu.astro'
import Footer from '@/components/page/Footer.astro'
import CatalogData from '@/components/CatalogData.astro'

const currentPath = Astro.url.pathname
const siteOrigin = Astro.url.origin

const { category } = Astro.params
const categoryLabel = category === 'all' ? 'Todos los Productos' : decodeURIComponent(category ?? 'all')

const categoryDescriptions: Record<string, string> = {
  'all': 'Catálogo completo de equipos de seguridad para bomberos, rescate e industria en Ecuador. Filtra por categoría, marca y precio.',
  'Estructural': 'Trajes estructurales, cascos, botas, guantes y capuchas para combate de incendios estructurales. Productos certificados NFPA y EN.',
  'Forestal': 'Trajes y equipos especializados para combate de incendios forestales. Certificados NFPA 1977 y USFS.',
  'Rescate': 'Herramientas hidráulicas, estabilizadores y equipos de rescate vehicular y en altura. Certificados NFPA 1936.',
  'HAZMAT': 'Detectores de gases, trajes químicos y equipos para materiales peligrosos y espacios confinados.',
  'Equipos': 'Cámaras térmicas, bombas contra incendios y compresores de aire respirable.',
  'Accesorios': 'Linternas, herramientas manuales y accesorios complementarios para operaciones de emergencia.',
  'Herramientas': 'Herramientas especializadas para operaciones de rescate y emergencia.',
}
const categoryDesc = categoryDescriptions[category ?? 'all'] ?? categoryDescriptions['all']

const categoryTitles: Record<string, string> = {
  'all': 'Catálogo de Equipos de Bomberos y Rescate',
  'Estructural': 'Equipos Estructurales para Bomberos',
  'Forestal': 'Equipos Forestales para Combate de Incendios',
  'Rescate': 'Equipos y Herramientas de Rescate',
  'HAZMAT': 'Equipos HAZMAT y Materiales Peligrosos',
  'Equipos': 'Equipos Generales de Seguridad',
  'Accesorios': 'Accesorios y Herramientas de Emergencia',
  'Herramientas': 'Herramientas Especializadas de Rescate',
}
const seoTitle = `${categoryTitles[category ?? 'all'] ?? categoryLabel} | PROTON Fire & Rescue Ecuador`

const categoryKeywords: Record<string, string> = {
  'all': 'catálogo equipos bomberos, filtrar productos seguridad, equipos contra incendios Ecuador, trajes bombero catálogo',
  'Estructural': 'trajes estructurales bomberos, cascos bombero NFPA, botas bombero Ecuador, guantes protección incendios, equipos estructurales',
  'Forestal': 'trajes forestales bomberos, equipos incendios forestales, NFPA 1977, protección forestal Ecuador',
  'Rescate': 'herramientas rescate hidráulicas, equipos rescate vehicular, estabilizadores rescate, NFPA 1936 Ecuador',
  'HAZMAT': 'detectores gases, trajes químicos HAZMAT, equipos materiales peligrosos, espacios confinados Ecuador',
  'Equipos': 'cámaras térmicas bomberos, bombas contra incendios, compresores aire respirable Ecuador',
  'Accesorios': 'linternas bomberos, herramientas manuales emergencia, accesorios equipos bomberos Ecuador',
  'Herramientas': 'herramientas rescate especializadas, herramientas emergencia bomberos Ecuador',
}
const seoKeywords = categoryKeywords[category ?? 'all'] ?? categoryKeywords['all']

const catalogJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${categoryLabel} - Catálogo PROTON Fire & Rescue`,
    description: categoryDesc,
    url: `${siteOrigin}/catalogo/${category}`,
    image: `${siteOrigin}/images/products.webp`,
    inLanguage: 'es',
    isPartOf: { '@id': `${siteOrigin}/#website` },
    provider: { '@id': `${siteOrigin}/#organization` },
    about: {
      '@type': 'Thing',
      name: categoryLabel,
      description: categoryDesc
    },
    significantLink: [
      `${siteOrigin}/productos`,
      `${siteOrigin}/contactanos`,
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteOrigin },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Catálogo',
        item: `${siteOrigin}/catalogo/all`
      },
      ...(category && category !== 'all'
        ? [
            {
              '@type': 'ListItem',
              position: 3,
              name: categoryLabel,
              item: `${siteOrigin}/catalogo/${category}`
            }
          ]
        : [])
    ]
  }
]
---

<Layout
  title={seoTitle}
  description={categoryDesc}
  keywords={seoKeywords}
  jsonLd={catalogJsonLd}
>
  <Menu currentPath={currentPath} />

  <main>
    <!-- Header Section -->
    <section class='py-16 bg-white dark:bg-[#0b0b12]'>
      <div class='max-w-360 mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mt-16'>
          <h1
            class='text-3xl md:text-4xl lg:text-[40px] font-bold text-[#2f2f3b] dark:text-white mb-3'
          >
            Busca el producto de tu interés
          </h1>
          <p class='text-gray-500 dark:text-[#9ca3b8] max-w-xl mx-auto'>
            Explora nuestro catálogo completo y encuentra el equipo perfecto
            para tus necesidades
          </p>
        </div>
      </div>
    </section>

    <!-- Product Catalog Section -->
    <section class='pb-20 bg-white dark:bg-[#0b0b12]'>
      <div class='max-w-360 mx-auto px-4 sm:px-6 lg:px-8'>
        <CatalogData server:defer category={category}>
          <div
            slot='fallback'
            class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6'
          >
            {
              Array.from({ length: 8 }).map((_, i) => (
                <div
                  key={i}
                  class='bg-white dark:bg-[#1a1a2e] rounded-2xl border border-gray-100 dark:border-[#2a2a3e] overflow-hidden'
                >
                  <div class='relative aspect-3/4 overflow-hidden bg-gray-50 dark:bg-[#12121e] p-4'>
                    <div class='w-full h-full bg-gray-200 animate-pulse rounded-xl' />
                  </div>
                  <div class='p-4 space-y-3'>
                    <div class='h-4 bg-gray-200 animate-pulse rounded w-3/4' />
                    <div class='h-3 bg-gray-200 animate-pulse rounded w-1/2' />
                    <div class='h-3 bg-gray-200 animate-pulse rounded w-2/3' />
                    <div class='h-9 bg-gray-200 animate-pulse rounded' />
                  </div>
                </div>
              ))
            }
          </div>
        </CatalogData>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
