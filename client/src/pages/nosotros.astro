---
import Layout from "@/layouts/Layout.astro";
import Menu from "@/components/page/Menu.astro";
import Footer from "@/components/page/Footer.astro";
import InfiniteCarousel from "@/components/InfiniteCarousel.astro";
import ScrollScale from "@/components/ScrollScale.astro";
import CTAButton from "@/components/ui/CTAButton.astro";
import { Image } from "astro:assets";

const currentPath = Astro.url.pathname;
const siteOrigin = Astro.url.origin;

// Ejemplo de imágenes para el carousel
const carouselImages = [
	{ src: "/images/carusel_1.webp", alt: "Bombero relajado en escaleras de concreto" },
	{ src: "/images/carusel_2.webp", alt: "Bombero en acción contra un incendio" },
	{ src: "/images/carusel_3.webp", alt: "Piton forestal en Manos de un Bombero" },
	{ src: "/images/carusel_4.webp", alt: "Cuarto con herramientas y vestimenta de bomberos" },
];

// Imágenes para carousel de marcas
const certificationImages = [
	{ src: "/certifications/cert1.png", alt: "Certificación National Fire Protection Association (NFPA)" },
	{ src: "/certifications/cert2.png", alt: "Certificación KFI (Korean Firer Institue)" },
	{ src: "/certifications/cert3.png", alt: "Certificación EN (Normas Europeas)" },
	{ src: "/certifications/cert4.png", alt: "Certificación UL Classified" },
	{ src: "/certifications/cert5.png", alt: "Certificación forestal US Forest Service (USFS)" },
	{ src: "/certifications/cert6.png", alt: "Certificación FM Approved" },
	{ src: "/certifications/cert7.png", alt: "Certificación NIOSH (National Institute for Occupational Safety and Health)" },
	{ src: "/certifications/cert8.png", alt: "Certificación EN 469 (o UNE-EN 469)" },
	{ src: "/certifications/cert9.png", alt: "Certificación International Standard Worldwide" },
	{ src: "/certifications/cert10.png", alt: "Certificación ATEX (del francés ATmosphères EXplosibles)" },
];

const nosotrosJsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "AboutPage",
		"name": "Quiénes Somos - PROTON Fire & Rescue Ecuador",
		"description": "Conoce PROTON Fire & Rescue, empresa ecuatoriana con más de 2 décadas de trayectoria en la importación y comercialización de equipos de seguridad para bomberos, rescate e industria. Técnicos altamente calificados y servicio posventa genuino.",
		"url": `${siteOrigin}/nosotros`,
		"image": `${siteOrigin}/images/hero-home.webp`,
		"inLanguage": "es",
		"isPartOf": { "@id": `${siteOrigin}/#website` },
		"mainEntity": {
			"@id": `${siteOrigin}/#organization`,
			"@type": "Organization",
			"name": "PROTON Fire & Rescue Ecuador",
			"alternateName": "Proton Fire & Rescue",
			"description": "Grupo humano alegre, honesto, trabajador y dedicado a brindar el mejor producto y servicio en equipos de seguridad para bomberos, rescate e industria en Ecuador. Técnicos altamente calificados con presencia en ferias internacionales como FDIC (EE.UU.) e INTERSCHUTZ (Alemania).",
			"foundingDate": "2000",
			"url": siteOrigin,
			"logo": `${siteOrigin}/logos/proton-logo.webp`,
			"areaServed": { "@type": "Country", "name": "Ecuador" },
			"slogan": "Protegiendo vidas, asegurando el futuro",
			"numberOfEmployees": { "@type": "QuantitativeValue", "minValue": 10, "maxValue": 50 },
			"knowsAbout": [
				"Equipos de protección contra incendios",
				"Equipos de rescate",
				"Equipos SCBA",
				"Trajes estructurales y forestales",
				"F-500 EA Agente Encapsulador",
				"FLAIM - Realidad virtual para bomberos",
				"Equipos HAZMAT",
				"Capacitación y formación de brigadas"
			],
			"event": [
				{ "@type": "Event", "name": "FDIC International", "location": { "@type": "Place", "name": "Indianapolis, Estados Unidos" }, "description": "Feria internacional de bomberos y equipos de emergencia" },
				{ "@type": "Event", "name": "INTERSCHUTZ", "location": { "@type": "Place", "name": "Hannover, Alemania" }, "description": "Feria mundial líder en seguridad, rescate y protección contra incendios" }
			]
		}
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteOrigin },
			{ "@type": "ListItem", "position": 2, "name": "Nosotros", "item": `${siteOrigin}/nosotros` }
		]
	}
];
---

<Layout
	title="Quiénes Somos | Proton Fire & Rescue Ecuador"
	description="Conoce PROTON Fire & Rescue, empresa ecuatoriana con más de 2 décadas de trayectoria en equipos de seguridad para bomberos, rescate e industria."
	keywords="PROTON Fire Rescue empresa, equipos bomberos Ecuador empresa, quienes somos PROTON, seguridad industrial Ecuador"
	jsonLd={nosotrosJsonLd}
>
	<Menu currentPath={currentPath}/>

	<main class="min-h-screen dark:bg-[#0b0b12]">
		<!-- Hero Section -->
		<section
			class="relative py-20 md:py-55 bg-linear-to-b from-white from-5% to-black overflow-hidden"
		>
			<div class="relative flex flex-col items-center z-10 max-w-360 mx-auto px-6 sm:px-6 lg:px-8">
				<Image
					src="/logos/proton.webp"
					alt="PROTON Fire & Rescue Logo"
					class="h-22 w-34 mb-2 brightness-0 invert"
					loading="lazy"
					width={136}
					height={88}
				/>
				<ScrollScale
					images={carouselImages.map((image) => image.src)}
					speed={30}
					client:visible
				/>
				<div class="text-center text-white" data-aos="fade-up" data-aos-delay="100">
					<h1
						class="text-3xl max-w-275 mx-auto sm:text-4xl md:text-5xl lg:text-[65px] font-bold mb-4 md:mb-6"
					
					>
						Líderes en soluciones bomberiles, rescate e
						industriales.
					</h1>
					<p class="text-sm sm:text-base md:text-xl max-w-3xl mx-auto leading-relaxed" data-aos="fade-up" data-aos-delay="200">
						En Proton Fire & Rescue, la calidad técnica se une a un
						servicio humano excepcional. Nos mantenemos a la
						vanguardia tecnológica para ofrecerte productos
						certificados y un acompañamiento posventa permanente.
						Nuestra meta es clara: cumplir tus expectativas con
						seriedad y soporte técnico de élite a nivel nacional.
					</p>
				</div>
			</div>
		</section>

		<!-- History Section -->
		<section class="py-20 bg-white dark:bg-[#0b0b12]">
			<div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
				<div
					class="flex flex-col-reverse md:grid md:grid-cols-2 gap-12 items-center"
				>
					<div>
						<h2
							class="text-3xl md:text-4xl font-bold text-[#2f2f3b] dark:text-white mb-6"
							data-aos="fade-right"
						>
							¿Quiénes somos?
						</h2>
						<p
							class="text-sm sm:text-base md:text-lg text-[#6b7280] dark:text-[#9ca3b8] mb-6 leading-relaxed"
							data-aos="fade-right" data-aos-delay="100"
						>
							Somos un grupo humano alegre, honesto, trabajador y
							dedicado a dar el mejor producto y/o servicio a
							nuestros clientes a los cuales nos debemos día a
							día; nos capacitamos constantemente y buscamos estar
							vigentes con las nuevas tecnologías para que la
							calidad de nuestra atención esté acorde a sus
							expectativas.
						</p>
						<p
							class="text-sm sm:text-base md:text-lg text-[#6b7280] dark:text-[#9ca3b8] mb-6 leading-relaxed"
							data-aos="fade-right" data-aos-delay="200"
						>
							Nos enfocamos en que nuestro servicio posventa sea
							genuino y damos un seguimiento personalizado a cada
							caso de venta exitosa, con el afán de que nuestros
							compradores palpen nuestro respaldo técnico y
							soporte permanente.
						</p>
						<p
							class="text-sm sm:text-base md:text-lg text-[#6b7280] dark:text-[#9ca3b8] mb-6 leading-relaxed"
							data-aos="fade-right" data-aos-delay="300"
						>
							Tenemos el privilegio de contar con técnicos
							altamente calificados, que hacen de nuestro equipo
							uno de los mejores a nivel nacional en el ámbito
							bomberil e industrial. Cuando requiera asistencia
							técnica de calidad, productos certificados, pero
							ante todo, seriedad y cumplimiento, piense en
							<strong>Proton Fire & Rescue</strong>.
						</p>
						<!-- TODO: Implementar valores por satisfacción -->
						<!-- <div class="grid grid-cols-3 gap-6 mt-8">
							<div class="text-center">
								<div
									class="text-4xl font-bold text-[#504aff] mb-2"
								>
									20+
								</div>
								<div class="text-[#6b7280]">
									Años de experiencia
								</div>
							</div>
							<div class="text-center">
								<div
									class="text-4xl font-bold text-[#504aff] mb-2"
								>
									1000+
								</div>
								<div class="text-[#6b7280]">
									Clientes satisfechos
								</div>
							</div>
							<div class="text-center">
								<div
									class="text-4xl font-bold text-[#504aff] mb-2"
								>
									50+
								</div>
								<div class="text-[#6b7280]">
									Marcas internacionales
								</div>
							</div>
						</div> -->
					</div>
					<div class="relative" data-aos="fade-left">
						<Image
							src="/images/hero-home.webp"
							alt="Imagen de fondo para la página de nosotros."
							class="w-full h-auto rounded-2xl shadow-xl"
							loading="lazy"
							width={600}
							height={400}
						/>
					</div>
				</div>
			</div>
		</section>

		<!-- Team Company Section -->
		<section class="to-white">
			<section class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center py-20">
					<div
						class="relative w-full min-h-105 sm:min-h-120 md:min-h-150 rounded-3xl md:rounded-[40px] overflow-hidden shadow-2xl"
						data-aos="zoom-in"
					>
						<!-- Background image with brightness filter -->
						<div
							class="absolute inset-0 bg-fixed bg-center bg-cover bg-no-repeat brightness-50"
							style="background-image: url('/images/atencion_cliente.webp'); background-blend-mode: overlay;"
						>
						</div>
						<!-- Content overlay -->
						<div
							class="absolute inset-0 flex flex-col items-center justify-center p-8 sm:p-12 md:p-16"
						>
							<h2
							class="text-xl sm:text-2xl md:text-4xl font-bold text-white mb-3 md:mb-4"
							>
								Nuestro equipo
							</h2>
							<p
							class="text-xs sm:text-sm md:text-lg text-white max-w-2xl mx-auto px-4 sm:px-6 md:px-0 leading-relaxed"
							>
								Detrás de cada solución en PROTON Fire & Rescue,
								hay un equipo de profesionales apasionados por
								tu éxito. Nuestros asesores no solo conocen el
								catálogo; entienden tus desafíos. Con una
								combinación de honestidad, alegría y rigor
								técnico, cada integrante de nuestro equipo de
								ventas está aquí para escucharte y guiarte hacia
								la decisión que mejor proteja tu inversión y tu
								seguridad.
							</p>

							<div class="flex flex-col sm:flex-row gap-4 mt-6 md:mt-10">
								<CTAButton href="/contactanos">
									Contáctanos
								</CTAButton>
							</div>
						</div>
					</div>

					<!-- TODO: Implementar carousel de usuarios -->
				</div>
			</section>
		</section>

		<!-- Values Section -->
		<section class="py-20">
			<div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8">
				<h2
					class="text-3xl md:text-4xl font-bold text-[#2f2f3b] dark:text-white text-center"
					data-aos="fade-up"
				>
					Nuestros Valores
				</h2>
				<p class="text-center text-[#6b7280] dark:text-[#9ca3b8] mt-5 mb-12 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
					Son los principios que guían todo lo que hacemos. Son la
					base de nuestra cultura y la razón de nuestro éxito.
				</p>

				<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
					<div class="bg-gradient-to-r from-slate-900 to-slate-700 rounded-3xl p-8 text-center shadow-xl" data-aos="fade-up" data-aos-delay="100">
						<div
							class="w-16 h-16 bg-[#504aff]/10 rounded-full flex items-center justify-center mx-auto mb-4"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-8 w-8 text-[#504aff]"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
								></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white mb-2">
							Calidad
						</h3>
						<p class="text-zinc-300">
							Productos certificados de las mejores marcas
							internacionales
						</p>
					</div>

					<div class="bg-gradient-to-r from-slate-900 to-slate-700 rounded-3xl p-8 text-center shadow-xl" data-aos="fade-up" data-aos-delay="200">
						<div
							class="w-16 h-16 bg-[#504aff]/10 rounded-full flex items-center justify-center mx-auto mb-4"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-8 w-8 text-[#504aff]"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
								></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white mb-2">
							Compromiso
						</h3>
						<p class="text-zinc-300">
							Dedicación total a la seguridad de nuestros clientes
						</p>
					</div>

					<div class="bg-gradient-to-r from-slate-900 to-slate-700 rounded-3xl p-8 text-center shadow-xl" data-aos="fade-up" data-aos-delay="300">
						<div
							class="w-16 h-16 bg-[#504aff]/10 rounded-full flex items-center justify-center mx-auto mb-4"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-8 w-8 text-[#504aff]"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
								></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white mb-2">
							Innovación
						</h3>
						<p class="text-zinc-300">
							Siempre a la vanguardia de la tecnología en
							seguridad
						</p>
					</div>

					<div class="bg-gradient-to-r from-slate-900 to-slate-700 rounded-3xl p-8 text-center shadow-xl" data-aos="fade-up" data-aos-delay="400">
						<div
							class="w-16 h-16 bg-[#504aff]/10 rounded-full flex items-center justify-center mx-auto mb-4"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-8 w-8 text-[#504aff]"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
								></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white mb-2">
							Servicio
						</h3>
						<p class="text-zinc-300">
							Atención personalizada y soporte técnico
							especializado
						</p>
					</div>
				</div>
			</div>
		</section>

		<section class="py-20 md:py-40">
			<div class="max-w-[1440px] mx-auto px-4">
				<p
					class="text-lg text-[#6b7280] dark:text-[#9ca3b8] text-center max-w-[632px] mx-auto mb-12"
					data-aos="fade-up"
				>
					Conocemos y distribuimos solo productos que cumplan con las
					siguientes certificaciones internacionales.
				</p>

				<InfiniteCarousel
					images={certificationImages}
					speed={30}
					direction="right"
				/>
			</div>
		</section>

	</main>

	<Footer />
</Layout>
