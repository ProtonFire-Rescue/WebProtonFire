---
import Layout from '@/layouts/Layout.astro'
import Menu from '@/components/page/Menu.astro'
import Footer from '@/components/page/Footer.astro'
import ProductPageData from '@/components/productos/ProductPageData.astro'
import { getProductBySlugQuery, getProductByIdQuery, resolveBackendUrl } from '@/utils/server'
import { slugify, productUrl } from '@/utils/slugify'

const { category, slug } = Astro.params
const currentPath = Astro.url.pathname
const siteOrigin = Astro.url.origin

// Fetch ligero para meta tags SEO (name, description, imagen, marca, categoría)
let productName = 'Producto'
let productDescription =
  'Equipos de seguridad profesional para bomberos y rescate.'
let productImage = '/og-image.jpg'
let productBrand = ''
let productCategory = ''
let productSlug = slug ?? ''
let productJsonLd: object | undefined

try {
  const strapiBaseUrl = resolveBackendUrl({ astro: Astro })
  const seoQuery = 'fields[0]=name&fields[1]=description&fields[2]=slug&populate[images][fields][0]=url&populate[images][fields][1]=alternativeText&populate[brand][fields][0]=name&populate[categories][fields][0]=name'

  // Race: fetch SEO data con timeout de 2s para no bloquear el render
  const seoFetch = getProductBySlugQuery(slug, seoQuery, {
    cacheTtlMs: 15000, baseUrl: strapiBaseUrl, astro: Astro
  })
  const timeout = new Promise((_, reject) =>
    setTimeout(() => reject(new Error('SEO fetch timeout')), 2000)
  )
  const { data } = (await Promise.race([seoFetch, timeout])) as any

  if (!data?.length) {
    // Legacy URL support: /producto/[documentId]/[slug]
    // If [category] looks like a Strapi documentId, try to resolve and redirect
    try {
      const legacyFetch = getProductByIdQuery(category, 'fields[0]=slug&populate[categories][fields][0]=name', {
        cacheTtlMs: 15000, baseUrl: strapiBaseUrl, astro: Astro
      })
      const { data: legacyData } = (await Promise.race([legacyFetch, timeout])) as any
      if (legacyData?.length) {
        const lp = legacyData[0]
        const legacyCat = lp.categories?.[0]?.name ?? 'producto'
        return Astro.redirect(productUrl(legacyCat, lp.slug ?? slug ?? ''), 301)
      }
    } catch {}
    return Astro.redirect('/catalogo')
  }

  const p = data[0]
  productName = p.name ?? productName
  productSlug = p.slug ?? productSlug
  productDescription = p.description
    ? `${p.description.substring(0, 160).replace(/\s+/g, ' ').trim()}...`
    : `${productName} - Equipos de seguridad profesional para bomberos y rescate en Ecuador.`
  productBrand = p.brand?.name ?? ''
  productCategory = p.categories?.[0]?.name ?? ''

  // Validate category slug — redirect to canonical URL if mismatch
  const expectedCatSlug = slugify(productCategory || 'producto')
  if (category !== expectedCatSlug) {
    return Astro.redirect(productUrl(productCategory, productSlug), 301)
  }

  if (p.images?.length) {
    const img = p.images[0]
    productImage = img.url?.startsWith('http')
      ? img.url
      : `${siteOrigin}${img.url}`
  }

  // JSON-LD Product structured data
  const canonicalUrl = `${siteOrigin}${productUrl(productCategory, productSlug)}`
  const productSchema = {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: productName,
    description: productDescription,
    image: productImage,
    url: canonicalUrl,
    sku: productSlug,
    ...(productBrand && { brand: { '@type': 'Brand', name: productBrand } }),
    ...(productCategory && { category: productCategory }),
    itemCondition: 'https://schema.org/NewCondition',
    offers: {
      '@type': 'Offer',
      url: canonicalUrl,
      availability: 'https://schema.org/InStock',
      priceCurrency: 'USD',
      itemCondition: 'https://schema.org/NewCondition',
      seller: { '@id': `${siteOrigin}/#organization` },
      shippingDetails: {
        '@type': 'OfferShippingDetails',
        shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'EC' },
        deliveryTime: {
          '@type': 'ShippingDeliveryTime',
          handlingTime: { '@type': 'QuantitativeValue', minValue: 1, maxValue: 15, unitCode: 'DAY' }
        }
      }
    }
  }
  const breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteOrigin },
      { '@type': 'ListItem', position: 2, name: 'Catálogo', item: `${siteOrigin}/catalogo/all` },
      ...(productCategory
        ? [{ '@type': 'ListItem', position: 3, name: productCategory, item: `${siteOrigin}/catalogo/${slugify(productCategory)}` }]
        : []),
      { '@type': 'ListItem', position: productCategory ? 4 : 3, name: productName, item: canonicalUrl }
    ]
  }
  productJsonLd = [productSchema, breadcrumbSchema]
} catch (e) {
  // Si falla el fetch, usamos los valores genéricos por defecto
}
const seoTitle = `${productName} - PROTON Fire & Rescue Ecuador`
const seoKeywords = [
  productBrand,
  productCategory,
  'equipos seguridad',
  'bomberos Ecuador',
  'PROTON Fire'
]
  .filter(Boolean)
  .join(', ')
---

<Layout
  title={seoTitle}
  description={productDescription}
  image={productImage}
  keywords={seoKeywords}
  type='product'
  jsonLd={productJsonLd}
>
  

  <main class="bg-white dark:bg-[#0b0b12]">
    <Menu currentPath={currentPath} />
    <ProductPageData slug={slug} server:defer>
    <section
      slot='fallback'
      class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-30'
    >
      <div class='grid lg:grid-cols-2 gap-12'>
        <div class='space-y-4'>
          <div
            class='aspect-square bg-gray-50 dark:bg-[#12121e] rounded-2xl overflow-hidden border border-gray-100 dark:border-[#2a2a3e]'
          >
            <div class='w-full h-full bg-gray-200 animate-pulse'></div>
          </div>
          <div class='flex gap-3'>
            {
              Array.from({ length: 4 }).map((_, i) => (
                <div
                  key={i}
                  class='w-20 h-20 bg-gray-200 dark:bg-[#1a1a2e] animate-pulse rounded-lg'
                />
              ))
            }
          </div>
        </div>
        <div class='space-y-4'>
          <div class='h-8 bg-gray-200 animate-pulse rounded w-3/4'></div>
          <div class='h-4 bg-gray-200 animate-pulse rounded w-1/2'></div>
          <div class='h-24 bg-gray-200 animate-pulse rounded'></div>
          <div class='h-12 bg-gray-200 animate-pulse rounded'></div>
        </div>
      </div>
    </section>
  </ProductPageData>

 
  </main>
   <Footer />
</Layout>
