---
import Layout from "@/layouts/Layout.astro";
import Menu from "@/components/page/Menu.astro";
import Footer from "@/components/page/Footer.astro";
import ProductPageData from "@/components/productos/ProductPageData.astro";
import { getProductByIdQuery, resolveBackendUrl } from "@/utils/server";

const { id } = Astro.params;
const currentPath = Astro.url.pathname;
const siteOrigin = Astro.url.origin;

// Fetch ligero para meta tags SEO (name, description, imagen, marca, categoría)
let productName = "Producto";
let productDescription = "Equipos de seguridad profesional para bomberos y rescate.";
let productImage = "/og-image.jpg";
let productBrand = "";
let productCategory = "";
let productJsonLd: object | undefined;

try {
  const strapiBaseUrl = resolveBackendUrl({ astro: Astro });

  // Race: fetch SEO data con timeout de 2s para no bloquear el render
  const seoFetch = getProductByIdQuery(
    id,
    'fields[0]=name&fields[1]=description&populate[images][fields][0]=url&populate[images][fields][1]=alternativeText&populate[brand][fields][0]=name&populate[categories][fields][0]=name',
    { cacheTtlMs: 15000, baseUrl: strapiBaseUrl, astro: Astro },
  );
  const timeout = new Promise((_, reject) => setTimeout(() => reject(new Error('SEO fetch timeout')), 2000));
  const { data } = await Promise.race([seoFetch, timeout]) as any;

  if (data?.length) {
    const p = data[0];
    productName = p.name ?? productName;
    productDescription = p.description
      ? `${p.description.substring(0, 160).replace(/\s+/g, ' ').trim()}...`
      : `${productName} - Equipos de seguridad profesional para bomberos y rescate en Ecuador.`;
    productBrand = p.brand?.name ?? "";
    productCategory = p.categories?.[0]?.name ?? "";

    if (p.images?.length) {
      const img = p.images[0];
      productImage = img.url?.startsWith("http") ? img.url : `${siteOrigin}${img.url}`;
    }

    // JSON-LD Product structured data
    productJsonLd = {
      "@context": "https://schema.org",
      "@type": "Product",
      name: productName,
      description: productDescription,
      image: productImage,
      url: `${siteOrigin}/producto/${id}`,
      ...(productBrand && { brand: { "@type": "Brand", name: productBrand } }),
      ...(productCategory && { category: productCategory }),
      offers: {
        "@type": "Offer",
        availability: "https://schema.org/InStock",
        priceCurrency: "USD",
        seller: { "@type": "Organization", name: "PROTON Fire & Rescue" },
      },
    };
  }
} catch (e) {
  // Si falla el fetch, usamos los valores genéricos por defecto
}

const seoTitle = `${productName} - PROTON Fire & Rescue`;
const seoKeywords = [productBrand, productCategory, "equipos seguridad", "bomberos Ecuador", "PROTON Fire"].filter(Boolean).join(", ");
---

<Layout
  title={seoTitle}
  description={productDescription}
  image={productImage}
  keywords={seoKeywords}
  type="product"
  jsonLd={productJsonLd}
>
  <Menu currentPath={currentPath} />
	
	<ProductPageData id={id} server:defer>
		<section slot="fallback" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 mt-30">
			<div class="grid lg:grid-cols-2 gap-12">
				<div class="space-y-4">
					<div class="aspect-square bg-gray-50 rounded-2xl overflow-hidden border border-gray-100">
						<div class="w-full h-full bg-gray-200 animate-pulse"></div>
					</div>
					<div class="flex gap-3">
						{Array.from({ length: 4 }).map((_, i) => (
							<div key={i} class="w-20 h-20 bg-gray-200 animate-pulse rounded-lg"></div>
						))}
					</div>
				</div>
				<div class="space-y-4">
					<div class="h-8 bg-gray-200 animate-pulse rounded w-3/4"></div>
					<div class="h-4 bg-gray-200 animate-pulse rounded w-1/2"></div>
					<div class="h-24 bg-gray-200 animate-pulse rounded"></div>
					<div class="h-12 bg-gray-200 animate-pulse rounded"></div>
				</div>
			</div>
		</section>
	</ProductPageData>
  
  <Footer />
</Layout>
