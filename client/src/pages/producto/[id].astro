---
import Layout from "../../layouts/Layout.astro";
import Menu from "../../components/Menu.astro";
import Footer from "../../components/Footer.astro";
import ProductPageData from "../../components/ProductPageData.astro";
import { getProductByIdQuery } from "../../utils/server";


const { id } = Astro.params;
const currentPath = Astro.url.pathname;

const { data: productMeta } = await getProductByIdQuery(
  id,
  'fields[0]=name',
  { cacheTtlMs: 15000 },
);

if (!productMeta?.length) {
  return Astro.redirect("/catalogo");
}
---

<Layout
  title={`${productMeta[0].name} - PROTON Fire & Rescue`}
  description={`${productMeta[0].name} - Equipos de seguridad profesional para bomberos y rescate.`}
  url={`https://protonfire.com/producto/${productMeta[0].id}`}
>
  <Menu currentPath={currentPath} />
  
	<ProductPageData id={id} server:defer>
		<section slot="fallback" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 mt-30">
			<div class="grid lg:grid-cols-2 gap-12">
				<div class="space-y-4">
					<div class="aspect-square bg-gray-50 rounded-2xl overflow-hidden border border-gray-100">
						<div class="w-full h-full bg-gray-200 animate-pulse"></div>
					</div>
					<div class="flex gap-3">
						{Array.from({ length: 4 }).map((_, i) => (
							<div key={i} class="w-20 h-20 bg-gray-200 animate-pulse rounded-lg"></div>
						))}
					</div>
				</div>
				<div class="space-y-4">
					<div class="h-8 bg-gray-200 animate-pulse rounded w-3/4"></div>
					<div class="h-4 bg-gray-200 animate-pulse rounded w-1/2"></div>
					<div class="h-24 bg-gray-200 animate-pulse rounded"></div>
					<div class="h-12 bg-gray-200 animate-pulse rounded"></div>
				</div>
			</div>
		</section>
	</ProductPageData>
  
  <Footer />
</Layout>
