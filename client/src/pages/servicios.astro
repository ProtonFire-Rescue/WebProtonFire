---
import Layout from "@/layouts/Layout.astro";
import Menu from "@/components/page/Menu.astro";
import Footer from "@/components/page/Footer.astro";

const currentPath = Astro.url.pathname;

const services = [
	{
		title: "SERVICIOS DE CAPACITACIÓN",
		description:
			"PROTON Fire & Rescue ofrece capacitación especializada y formación de brigadas en rescate, primeros auxilios y trabajos de alto riesgo. Somos expertos en la gestión de materiales peligrosos (Hazmat) y seguridad en altura, brindando soluciones técnicas integrales para que su industria opere bajo los más altos estándares de seguridad.",
		icon: "/icons/capacitacion.png",
	},
	{
		title: "SERVICIOS DE CONFECCIÓN",
		description:
			"Confeccionamos prendas técnicas de alta protección (ignífugas, dieléctricas y antidesgarro) utilizando insumos 100% certificados. Nuestras soluciones textiles garantizan seguridad avanzada contra riesgos específicos, combinando materiales especializados con componentes de alta durabilidad para entornos industriales exigentes.",
		icon: "/icons/confeccion.png",
	},
	{
		title: "SERVICIOS DE MANTENIMIENTO",
		description:
			"Ofrecemos un servicio técnico integral y mantenimiento especializado para equipos de protección crítica. Realizamos pruebas hidrostáticas, recarga de aire respirable tipo D y reparación certificada de equipos SCBA y sistemas para trabajos en altura, garantizando siempre la máxima operatividad y seguridad de su equipamiento.",
		icon: "/icons/mantenimiento.png",
	},
];

const maintenanceServices = [
	{
		name: "Gestión Integral de Extintores",
		description:
			"Aseguramos la potencia de tu primera respuesta. Realizamos recarga, mantenimiento y presurización de equipos PQS, CO2 y Púrpura K, bajo los más estrictos estándares de calidad.",
	},
	{
		name: "Cuidado de Equipos de Aire (SCBA)",
		description:
			"Tu respiración es nuestra prioridad. Ofrecemos mantenimiento multimarca, pruebas hidrostáticas, sanitización y recarga de aire respirable Grado D, garantizando aire puro en cada intervención.",
	},
	{
		name: "Reparación de Equipos de Altura",
		description:
			"Alargamos la vida útil de tu inversión. Somos expertos en la reparación de retráctiles y equipos normados para trabajo en alturas, asegurando que cada componente funcione a la perfección.",
	},
	{
		name: "Confección de Prendas Especiales",
		description:
			"Protección a medida para riesgos específicos. Diseñamos y fabricamos indumentaria técnica: ignífuga, antiabrasiva, dieléctrica y repelente a mosquitos, fusionando comodidad con máxima resistencia industrial.",
	},
];

const trainingServices = [
	{
		name: "Gestión Integral de Extintores",
		description:
			"Formación técnica avanzada para escenarios críticos. Capacitamos a tu personal en maniobras de rescate seguras y eficientes, dominando el entorno vertical con equipo especializado.",
	},
	{
		name: "Formación de Brigadas Industriales",
		description:
			"Transformamos a tus colaboradores en la primera línea de defensa. Diseñamos programas integrales para que tus brigadas actúen con liderazgo y eficacia ante cualquier incidente en planta.",
	},
	{
		name: "Primeros Auxilios",
		description:
			"Conocimiento vital para salvar vidas. Brindamos las herramientas teóricas y prácticas necesarias para estabilizar pacientes y reaccionar correctamente ante emergencias médicas.",
	},
	{
		name: "Alertas Volcánicas, Desastres y Evacuación",
		description:
			"Especialistas en prevención. Desarrollamos planes de respuesta y protocolos de evacuación ante fenómenos naturales, garantizando el resguardo de todo tu personal.",
	},
	{
		name: "Derrame y Contención de Hidrocarburos",
		description:
			"Protegemos tu operación y el entorno. Instruimos en técnicas de respuesta rápida y uso de materiales absorbentes para mitigar impactos ambientales y riesgos operativos.",
	},
	{
		name: "Gestión de Químicos y HAZMAT (Espacios Confinados)",
		description:
			"Seguridad máxima en entornos peligrosos. Certificamos a tu equipo en el manejo de sustancias tóxicas y operaciones seguras en espacios confinados bajo normativas internacionales.",
	},
	{
		name: "Trabajos en Altura",
		description:
			"Seguridad vertical para sectores clave. Capacitación específica para la industria eléctrica, telecomunicaciones y construcción, enfocada en la prevención de caídas y el uso correcto de equipos certificados.",
	},
];
---

<Layout
	title="Servicios y Capacitaciones | PROTON Fire & Rescue Ecuador"
	description="Descubre nuestros servicios de capacitación, confección y mantenimiento para equipos de seguridad de bomberos, rescate e industria en Ecuador."
	keywords="capacitación bomberos Ecuador, mantenimiento equipos SCBA, confección prendas ignífugas, formación brigadas industriales, HAZMAT Ecuador"
>
	<Menu currentPath={currentPath} />

	<main>
		<!-- Hero Section - Dark with gradient like index -->
		<section
			class="relative min-h-150 md:min-h-170 py-30 md:py-65 overflow-hidden md:mx-5 md:rounded-[55px]"
		>
			<!-- Background Image with overlay -->
			<div
							class="absolute inset-0 bg-fixed bg-center bg-cover bg-no-repeat brightness-50"
							style="background-image: url('/images/services.png'); background-blend-mode: overlay;"
						>
						</div>
			<div
				class="relative z-10 max-w-360 mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 pt-30 md:pt-10 pb-20"
			>
				<div class="max-w-3xl">
					<h1
						class="text-4xl md:text-5xl lg:text-[59px] font-bold text-white leading-tight mb-6"
						data-aos="fade-up" data-aos-delay="100"
					>
						Nuestros Servicios
					</h1>
					<p
						class="text-base md:text-xl text-white/90 leading-relaxed mb-8"
						data-aos="fade-up" data-aos-delay="200"
					>
						Además de ofrecer productos, PROTON Fire & Rescue ofrece
						un catálogo de servicios especializados para tu
						institución o empresa. Capacitamos, confeccionamos y
						mantenemos tus equipos de seguridad.
					</p>
				</div>
			</div>
		</section>
		<!-- Capacitación y Formación Section - Two Column Layout -->
		
		<section
			class="py-20 bg-linear-90 from-blue-100 via-white to-gray-100"
			id="servicios"
		>
			<div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid gap-12 items-start">
					<!-- Left Column: Capacitación y Formación -->
					<div class="grid md:grid-cols-3 gap-8 md:pl-20">
						<div>
							<h2
								class="text-2xl md:text-3xl font-bold text-[#2f2f3b] mb-8"
								data-aos="fade-up"
							>
								Capacitación y Formación
							</h2>
							<p class="text-[#6b7280] mb-8">
								Preparamos a tu equipo para responder con
								precisión cuando cada segundo cuenta.
							</p>
						</div>

						<div class="space-y-4">
							{
								trainingServices.map((item) => (
									<div class="border-b border-gray-200 pb-4 last:border-0" data-aos="fade-up">
										<div class="flex items-start gap-3">
											<div class="w-6 h-6 rounded-full bg-[#504aff] flex items-center justify-center shrink-0 mt-1">
												<svg
													class="w-4 h-4 text-white"
													fill="none"
													stroke="currentColor"
													viewBox="0 0 24 24"
												>
													<path
														stroke-linecap="round"
														stroke-linejoin="round"
														stroke-width="2"
														d="M5 13l4 4L19 7"
													/>
												</svg>
											</div>
											<h2 class=" text-xl font-bold text-[#2f2f3b] mb-1">
												{item.name}
											</h2>
										</div>
										<p class="text-[#6b7280]">
											{item.description}
										</p>
										<a href={`https://wa.me/593982487322?text=Hola, me gustaría saber información acerca del servicio de *${item.name}*`} target="_blank" rel="noopener noreferrer" class="text-[#504aff] hover:underline">Solicitar</a>
									</div>
								))
							}
						</div>
						<div></div>
					</div>
					<hr
						class="border-gray-200 border-dashed my-8 w-full border"
					/>

					<!-- Right Column: Maintenance Services -->
					
					<div
						class="flex flex-col-reverse md:grid md:grid-cols-3 gap-8 pr-20"
					>
						<div></div>

						<div class="space-y-4">
							{
								maintenanceServices.map((item) => (
									<div class="border-b border-gray-200 pb-4 last:border-0" data-aos="fade-up">
										<div class="flex items-start gap-3">
											<div class="w-6 h-6 rounded-full bg-[#504aff] flex items-center justify-center shrink-0 mt-1">
												<svg
													class="w-4 h-4 text-white"
													fill="none"
													stroke="currentColor"
													viewBox="0 0 24 24"
												>
													<path
														stroke-linecap="round"
														stroke-linejoin="round"
														stroke-width="2"
														d="M5 13l4 4L19 7"
													/>
												</svg>
											</div>
											<h2 class=" text-xl font-bold text-[#2f2f3b] mb-1">
												{item.name}
											</h2>
										</div>
										<p class="text-[#6b7280]">
											{item.description}
										</p>
										<a href={`https://wa.me/593982487322?text=Hola, me gustaría saber información acerca del servicio de *${item.name}*`} target="_blank" rel="noopener noreferrer" class="text-[#504aff] hover:underline">Solicitar</a>
									</div>
								))
							}
						</div>

						<div>
							<h2
								class="text-2xl md:text-3xl font-bold text-[#2f2f3b] mb-8"
								data-aos="fade-up"
							>
								Soporte Técnico, Mantenimiento y Confección
							</h2>
							<p class="text-[#6b7280] mb-8 leading-relaxed">
								Tecnología y respaldo técnico para garantizar la
								operatividad de tus equipos.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Images Section -->
		<section class="py-20">
			<div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid md:grid-cols-2 gap-8">
					<a
						class="relative rounded-3xl overflow-hidden shadow-2xl"
						href="#servicios"
						data-aos="fade-right"
					>
						<img
							src="/images/carusel_2.png"
							alt="Capacitación PROTON"
							class="w-full h-80 object-cover"
							loading="lazy"
						/>
						<div
							class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/70 to-transparent"
						>
							<p class="text-white font-semibold">
								Capacitación en campo
							</p>
						</div>
					</a>
					<a
						class="relative rounded-3xl overflow-hidden shadow-2xl"
						href="/productos"
						data-aos="fade-left"
					>
						<img
							src="/images/carusel_3.png"
							alt="Equipos PROTON"
							class="w-full h-80 object-cover"
							loading="lazy"
						/>
						<div
							class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/70 to-transparent"
						>
							<p class="text-white font-semibold">
								Equipos de protección
							</p>
						</div>
					</a>
				</div>
			</div>
		</section>

		<!-- CTA Section - Dark Card Style -->
		<section
			class="py-60 bg-linear-to-b from-purple-100 via-white to-blue-100"
		>
			<div class="max-w-360 mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h2 class="text-4xl lg:text-5xl font-bold mb-6" data-aos="fade-up">
					¿Por qué elegir nuestros servicios?
				</h2>
				<p class="text-gray-600 text-xl max-w-2xl mx-auto mb-8" data-aos="fade-up" data-aos-delay="100">
					Cada uno de nuestros servicios cuenta con el respaldo de
					técnicos calificados y está diseñado para superar las
					expectativas de cumplimiento y seguridad. En PROTON Fire &
					Rescue, no solo cumplimos con la norma, elevamos el estándar
					de protección para tu empresa.
				</p>
				<div 
					data-aos="fade-up" 
					data-aos-delay="200"
				>
				<a
					href="/contactanos"
					class="inline-block bg-[#504aff] text-white px-10 py-5 rounded-full font-semibold text-lg hover:bg-[#3f3bcc] transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1"
				>
					Contáctanos
				</a>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
