---
import Layout from '@/layouts/Layout.astro'
import Menu from '@/components/page/Menu.astro'
import Footer from '@/components/page/Footer.astro'
import CTAButton from '@/components/ui/CTAButton.astro'
import BrandsCarouselData from '@/components/BrandsCarouselData.astro'
import ProductsAreaData from '@/components/productos/ProductsAreaData.astro'

const currentPath = Astro.url.pathname
const siteOrigin = Astro.url.origin


const productosJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Equipos de Bomberos y Rescate - PROTON Fire & Rescue',
    description:
      'Catálogo completo de equipos de seguridad para bomberos, rescate e industria en Ecuador. Trajes estructurales, forestales, herramientas de rescate, SCBA, HAZMAT y tecnología de entrenamiento. Marcas certificadas NFPA, EN, ISO y UL.',
    url: `${siteOrigin}/productos`,
    image: `${siteOrigin}/images/products.webp`,
    inLanguage: 'es',
    isPartOf: { '@id': `${siteOrigin}/#website` },
    about: {
      '@type': 'Thing',
      name: 'Equipos de seguridad para bomberos, rescate e industria'
    },
    provider: { '@id': `${siteOrigin}/#organization` },
    mainEntity: {
      '@type': 'ItemList',
      name: 'Líneas de productos PROTON Fire & Rescue',
      numberOfItems: 8,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Equipos Estructurales', url: `${siteOrigin}/catalogo/Estructural`, description: 'Trajes, cascos, botas, guantes y capuchas para combate de incendios estructurales' },
        { '@type': 'ListItem', position: 2, name: 'Equipos Forestales', url: `${siteOrigin}/catalogo/Forestal`, description: 'Trajes y equipos para combate de incendios forestales' },
        { '@type': 'ListItem', position: 3, name: 'Equipos de Rescate', url: `${siteOrigin}/catalogo/Rescate`, description: 'Herramientas hidráulicas, estabilizadores y equipos de rescate vehicular y en altura' },
        { '@type': 'ListItem', position: 4, name: 'Equipos HAZMAT', url: `${siteOrigin}/catalogo/HAZMAT`, description: 'Detectores de gases, trajes químicos y equipos para espacios confinados' },
        { '@type': 'ListItem', position: 5, name: 'Equipos Generales', url: `${siteOrigin}/catalogo/Equipos`, description: 'Cámaras térmicas, bombas y compresores de aire' },
        { '@type': 'ListItem', position: 6, name: 'F-500 EA Agente Encapsulador', url: `${siteOrigin}/productos/f-500`, description: 'Agente encapsulador multiclase biodegradable para extinción de incendios A, B, C, D y K' },
        { '@type': 'ListItem', position: 7, name: 'FLAIM FTS Entrenamiento VR', url: `${siteOrigin}/productos/flaim`, description: 'Sistema de realidad virtual para formación de bomberos con escenarios 3D hiperrealistas' },
        { '@type': 'ListItem', position: 8, name: 'Accesorios y Herramientas', url: `${siteOrigin}/catalogo/Accesorios`, description: 'Linternas, herramientas manuales y accesorios complementarios' },
      ]
    }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteOrigin },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Productos',
        item: `${siteOrigin}/productos`
      }
    ]
  }
]
---

<Layout
  title='Equipos de Bomberos y Rescate en Ecuador | PROTON Fire & Rescue Ecuador'
  description='Descubre nuestro catálogo de equipos de seguridad para bomberos, rescate e industria. Trabajamos con las mejores marcas internacionales.'
  keywords='productos bomberos Ecuador, equipos contra incendios, trajes bombero, SCBA Ecuador, equipos rescate, F-500, FLAIM VR, equipos seguridad industrial'
  jsonLd={productosJsonLd}
>
  <Menu currentPath={currentPath}/>

  <main class="min-h-screen dark:bg-[#0b0b12]">
    <!-- Hero Section - Dark with gradient -->
    <section
      class='relative bg-linear-to-b from-1% from-white to-black md:bg-white min-h-150 md:min-h-175 py-20 md:py-55 overflow-hidden'
    >
      <!-- Large rounded gradient circle background -->
      <div
        class='hidden md:absolute inset-x-1 bottom-20 flex items-center justify-center pointer-events-none'
      >
        <div
          class='w-[140%] md:w-[120%] aspect-square rounded-full bg-linear-to-b from-60% from-black to-white'
          style='background-image:  ;'
        >
        </div>
      </div>
      <div
        class='absolute inset-0 bg-fixed bg-center bg-cover bg-no-repeat brightness-40'
        style="background-image: url('/images/products.webp'); background-blend-mode: overlay;"
      >
      </div>
      <div
        class='relative z-10 max-w-360 mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 pt-20 md:pt-10 pb-20 text-center'
      >
        <h1
          class='text-4xl md:text-5xl lg:text-[65px] font-bold text-white leading-tight mb-6'
          data-aos='fade-up'
          data-aos-delay='100'
        >
          Equipamiento de clase mundial<br />al alcance de tu mano
        </h1>
        <p
          class='text-base md:text-xl text-white/80 max-w-2xl mx-auto mb-10'
          data-aos='fade-up'
          data-aos-delay='200'
        >
          La protección y seguridad que usted necesita, con la representación de
          las mejores marcas y líderes, consolidando cada día nuestra oferta
          técnica para el gremio bomberil, de rescate e industrial.
        </p>
        <div data-aos='fade-up' data-aos-delay='300'>
          <CTAButton href='/catalogo/all'>
            Ver Catálogo
          </CTAButton>
        </div>
      </div>
    </section>

    <!-- Brands Carousel Section -->
    <section class='py-16 bg-white dark:bg-[#0b0b12]'>
      <div class='max-w-360 mx-auto px-4'>
        <BrandsCarouselData
          speed={25}
          direction='left'
          imageClass='h-8 md:h-10 lg:h-12 w-auto object-contain opacity-80 hover:opacity-100 transition-all duration-300'
          server:defer
        >
          <div slot='fallback' class='flex items-center gap-8 overflow-hidden'>
            {Array.from({ length: 6 }).map(() => (
              <div class='shrink-0 w-24 h-16 md:w-32 md:h-20 bg-gray-100 dark:bg-[#1a1a2e] rounded-md animate-pulse' />
            ))}
          </div>
        </BrandsCarouselData>
      </div>
    </section>

    <!-- Products Area Section -->
    <section
      id='productos'
      class='py-20 bg-linear-180 from-orange-50 via-white to-blue-100 dark:from-[#0b0b12] dark:via-[#12121e] dark:to-[#0b0b12]'
    >
      <div class='max-w-360 mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2
            class='text-3xl md:text-4xl lg:text-[48px] font-bold text-[#2f2f3b] dark:text-white mb-4'
            data-aos='fade-up'
          >
            Área de productos
          </h2>
          <p
            class='text-lg text-[#6b7280] dark:text-[#9ca3b8] max-w-3xl mx-auto'
            data-aos='fade-up'
            data-aos-delay='100'
          >
            La mejor calidad, diseño y precio, respaldados por los mejores
            distribuidores y representantes de las empresas líderes nacionales
            en equipos de protección contra incendios.
          </p>
        </div>

        <ProductsAreaData server:defer>
          <div slot='fallback'>
            {
              Array.from({ length: 2 }).map((_, sectionIdx) => (
                <div class='mb-16' key={`section-${sectionIdx}`}>
                  <div class='h-6 bg-gray-200 animate-pulse rounded w-48 mb-8' />
                  <div class='grid grid-cols-1 md:grid-cols-4 gap-6'>
                    {Array.from({ length: 4 }).map((_, i) => (
                      <div class='group' key={`sk-${sectionIdx}-${i}`}>
                        <div class='bg-white dark:bg-[#1a1a2e] rounded-2xl border border-gray-100 dark:border-[#2a2a3e] overflow-hidden'>
                          <div class='relative aspect-3/4 overflow-hidden bg-gray-50 p-4'>
                            <div class='w-full h-full bg-gray-200 animate-pulse rounded-xl' />
                          </div>
                          <div class='p-4 space-y-3'>
                            <div class='h-4 bg-gray-200 animate-pulse rounded w-3/4' />
                            <div class='h-3 bg-gray-200 animate-pulse rounded w-1/2' />
                            <div class='h-9 bg-gray-200 animate-pulse rounded' />
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </ProductsAreaData>
      </div>
    </section>

    <!-- Certifications Section -->
    <section class='py-20 bg-[#f8f9fa] dark:bg-[#12121e]'>
      <div class='max-w-360 mx-auto px-4 text-center'>
        <p
          class='text-lg text-[#6b7280] dark:text-[#9ca3b8] max-w-3xl mx-auto mb-12'
          data-aos='fade-up'
        >
          Estos productos fueron seleccionados bajo excelentes estándares y
          certificaciones internacionales.
        </p>

        <div
          class='flex flex-wrap justify-center items-center gap-8 md:gap-12'
          data-aos='fade-up'
          data-aos-delay='100'
        >
          <!-- Certification placeholders - using text badges -->
          <div class='flex items-center gap-2 text-[#6b7280] dark:text-[#9ca3b8]'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='24'
              height='24'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='1.5'
              stroke-linecap='round'
              stroke-linejoin='round'
              class='text-[#504aff]'
            >
              <path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'></path>
              <path d='m9 12 2 2 4-4'></path>
            </svg>
            <span class='font-semibold'>NFPA</span>
          </div>
          <div class='flex items-center gap-2 text-[#6b7280] dark:text-[#9ca3b8]'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='24'
              height='24'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='1.5'
              stroke-linecap='round'
              stroke-linejoin='round'
              class='text-[#504aff]'
            >
              <circle cx='12' cy='12' r='10'></circle>
              <path d='m9 12 2 2 4-4'></path>
            </svg>
            <span class='font-semibold'>CE</span>
          </div>
          <div class='flex items-center gap-2 text-[#6b7280] dark:text-[#9ca3b8]'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='24'
              height='24'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='1.5'
              stroke-linecap='round'
              stroke-linejoin='round'
              class='text-[#504aff]'
            >
              <path d='M12 2v4'></path>
              <path d='m5 5 2.8 2.8'></path>
              <path d='m19 5-2.8 2.8'></path>
              <circle cx='12' cy='12' r='4'></circle>
              <path d='M12 16v4'></path>
              <path d='m5 19 2.8-2.8'></path>
              <path d='m19 19-2.8-2.8'></path>
            </svg>
            <span class='font-semibold'>ISO</span>
          </div>
          <div class='flex items-center gap-2 text-[#6b7280] dark:text-[#9ca3b8]'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='24'
              height='24'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='1.5'
              stroke-linecap='round'
              stroke-linejoin='round'
              class='text-[#504aff]'
            >
              <path
                d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'
              >
              </path>
              <polyline points='14 2 14 8 20 8'></polyline>
              <path d='m9 15 2 2 4-4'></path>
            </svg>
            <span class='font-semibold'>UL</span>
          </div>
          <div class='flex items-center gap-2 text-[#6b7280] dark:text-[#9ca3b8]'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='24'
              height='24'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='1.5'
              stroke-linecap='round'
              stroke-linejoin='round'
              class='text-[#504aff]'
            >
              <path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'></path>
              <path d='m9 12 2 2 4-4'></path>
            </svg>
            <span class='font-semibold'>EN</span>
          </div>
          <div class='flex items-center gap-2 text-[#6b7280] dark:text-[#9ca3b8]'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='24'
              height='24'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='1.5'
              stroke-linecap='round'
              stroke-linejoin='round'
              class='text-[#504aff]'
            >
              <circle cx='12' cy='12' r='10'></circle>
              <path d='M8 12h8'></path>
              <path d='M12 8v8'></path>
            </svg>
            <span class='font-semibold'>ANSI</span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
