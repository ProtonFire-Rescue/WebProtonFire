---
import Layout from "@/layouts/Layout.astro";
import Menu from "@/components/page/Menu.astro";
import Footer from "@/components/page/Footer.astro";
import CTAButton from "@/components/ui/CTAButton.astro";
---

<Layout
	title="Página no encontrada | PROTON Fire & Rescue Ecuador"
	description="La página que buscas no existe o fue movida."
>
	<Menu />

	<main class="min-h-screen flex items-center justify-center bg-white dark:bg-[#0b0b12] px-4">
		<div class="max-w-lg w-full text-center py-20">
			<!-- Icono decorativo -->
			<div class="mx-auto mb-8 w-24 h-24 rounded-full bg-[#504aff]/10 flex items-center justify-center" data-aos="zoom-in">
				<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#504aff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8"/>
					<path d="m21 21-4.3-4.3"/>
					<path d="M8 11h6"/>
				</svg>
			</div>

			<!-- Código de error -->
			<p class="text-sm font-semibold text-[#504aff] tracking-widest uppercase mb-3" data-aos="fade-up" data-aos-delay="100">Error 404</p>

			<!-- Título -->
			<h1 class="text-3xl md:text-4xl font-bold text-[#2f2f3b] dark:text-white mb-4" data-aos="fade-up" data-aos-delay="200">
				Página no encontrada
			</h1>

			<!-- Descripción -->
			<p class="text-gray-500 dark:text-[#9ca3b8] mb-10 max-w-md mx-auto leading-relaxed" data-aos="fade-up" data-aos-delay="300">
				Lo sentimos, la página que buscas no existe, fue movida o está temporalmente fuera de servicio.
			</p>

			<!-- CTAs -->
			<div class="flex flex-col sm:flex-row gap-4 justify-center" data-aos="fade-up" data-aos-delay="400">
				<CTAButton href="/" size="sm">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
					Ir al inicio
				</CTAButton>
				<CTAButton href="/catalogo/all" variant="outline" size="sm">
					Ver catálogo
				</CTAButton>
			</div>
		</div>
	</main>

	<Footer />
</Layout>
