---
import Layout from "@/layouts/Layout.astro";
import Menu from "@/components/page/Menu.astro";
import Footer from "@/components/page/Footer.astro";
---

<Layout
	title="Error del servidor | PROTON Fire & Rescue Ecuador"
	description="Ha ocurrido un error inesperado. Por favor, intenta de nuevo."
>
	<Menu />

	<main class="min-h-screen flex items-center justify-center bg-white px-4">
		<div class="max-w-lg w-full text-center py-20">
			<!-- Icono decorativo -->
			<div class="mx-auto mb-8 w-24 h-24 rounded-full bg-red-50 flex items-center justify-center" data-aos="zoom-in">
				<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
					<path d="M12 9v4"/>
					<path d="M12 17h.01"/>
				</svg>
			</div>

			<!-- Código de error -->
			<p class="text-sm font-semibold text-red-500 tracking-widest uppercase mb-3" data-aos="fade-up" data-aos-delay="100">Error 500</p>

			<!-- Título -->
			<h1 class="text-3xl md:text-4xl font-bold text-[#2f2f3b] mb-4" data-aos="fade-up" data-aos-delay="200">
				Algo salió mal
			</h1>

			<!-- Descripción -->
			<p class="text-gray-500 mb-10 max-w-md mx-auto leading-relaxed" data-aos="fade-up" data-aos-delay="300">
				Ha ocurrido un error inesperado en nuestro servidor. Por favor, intenta nuevamente en unos momentos.
			</p>

			<!-- CTAs -->
			<div class="flex flex-col sm:flex-row gap-4 justify-center" data-aos="fade-up" data-aos-delay="400">
				<button
					onclick="window.location.reload()"
					class="inline-flex items-center justify-center gap-2 bg-[#504aff] text-white font-semibold px-8 py-3.5 rounded-full hover:bg-[#3f3bcc] transition-all duration-300 shadow-md shadow-[#504aff]/20 hover:shadow-lg hover:shadow-[#504aff]/30 hover:-translate-y-0.5 text-sm cursor-pointer"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 21h5v-5"/></svg>
					Reintentar
				</button>
				<a
					href="/"
					class="inline-flex items-center justify-center gap-2 border-2 border-gray-200 text-[#2f2f3b] font-semibold px-8 py-3.5 rounded-full hover:border-[#504aff] hover:text-[#504aff] transition-all duration-300 text-sm"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
					Ir al inicio
				</a>
			</div>
		</div>
	</main>

	<Footer />
</Layout>
