---
import ProductDetail from '@/components/react-island/ProductDetail'
import RelatedProducts from '@/components/react-island/RelatedProducts'
import { BACKEND_URL } from '@/utils/constants'
import { getProductBySlugQuery, resolveBackendUrl } from '@/utils/server'
import type { ProductView, StrapiProduct } from '@/types/types'

const { slug } = Astro.props

const strapiBaseUrl = resolveBackendUrl({ astro: Astro })
const publicBackendUrl = strapiBaseUrl || BACKEND_URL
const { data: product } = await getProductBySlugQuery(
  slug,
  'fields[0]=name&fields[1]=description&fields[2]=Genero&fields[3]=slug&populate[categories][fields][0]=name&populate[model][fields][0]=name&populate[brand][fields][0]=name&populate[images][fields][0]=url&populate[images][fields][1]=alternativeText&populate[certifications][fields][0]=name&populate[certifications][fields][1]=description',
  { cacheTtlMs: 15000, baseUrl: strapiBaseUrl, astro: Astro }
)

if (!product?.length) {
  return Astro.redirect('/catalogo')
}

const toProductView = (p: StrapiProduct): ProductView => ({
  id: p.id,
  documentId: p.documentId,
  slug: p.slug,
  name: p.name,
  images: (p.images ?? []).map((image) => ({
    id: image.id,
    url: image.url,
    alt: image.alternativeText ?? ''
  })),
  category: p.categories?.[0]?.name ?? '',
  categories: p.categories?.map((category) => category.name) ?? [],
  brand: p.brand?.name ?? '',
  model: p.model?.name ?? '',
  description: p.description,
  genero: p.Genero ?? 'N/A',
  certifications: (p.certifications ?? []).map((cert) => ({
    id: cert.id,
    name: cert.name,
    description: cert.description
  }))
})

const productFilter = toProductView(product[0])
const categoryName = product[0].categories?.[0]?.name ?? ''
---

<ProductDetail product={productFilter} client:load />
<RelatedProducts
  categoryName={categoryName}
  excludeId={product[0].documentId}
  backendUrl={publicBackendUrl}
  client:idle
/>

<!-- Meta tags SEO se manejan server-side en producto/[id].astro -->
