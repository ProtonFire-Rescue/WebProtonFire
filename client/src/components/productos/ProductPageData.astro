---
import ProductDetail from "@/components/react-island/ProductDetail";
import RelatedProducts from "@/components/react-island/RelatedProducts";
import { BACKEND_URL } from "@/utils/contants";
import { getProductByIdQuery, resolveBackendUrl } from "@/utils/server";
import type { ProductView, StrapiProduct } from "@/types/types";

const { id } = Astro.props;

const strapiBaseUrl = resolveBackendUrl({ astro: Astro });
const publicBackendUrl = strapiBaseUrl || BACKEND_URL;
const { data: product } = await getProductByIdQuery(
  id,
  'fields[0]=name&fields[1]=description&populate[categories][fields][0]=name&populate[model][fields][0]=name&populate[brand][fields][0]=name&populate[images][fields][0]=url&populate[images][fields][1]=alternativeText',
  { cacheTtlMs: 15000, baseUrl: strapiBaseUrl, astro: Astro },
);

if (!product?.length) {
  return Astro.redirect("/catalogo");
}

const toProductView = (p: StrapiProduct): ProductView => ({
  id: p.id,
  name: p.name,
  images: (p.images ?? []).map((image) => ({
    id: image.id,
    url: image.url,
    alt: image.alternativeText ?? "",
  })),
  category: p.categories?.[0]?.name ?? "",
  categories: p.categories?.map((category) => category.name) ?? [],
  brand: p.brand?.name ?? "",
  model: p.model?.name ?? "",
  description: p.description,
});

const productFilter = toProductView(product[0]);
const categoryName = product[0].categories?.[0]?.name ?? '';
---

<ProductDetail product={productFilter} client:load />
<RelatedProducts 
  categoryName={categoryName} 
  excludeId={product[0].id} 
  backendUrl={publicBackendUrl}
  client:idle 
/>

<script define:vars={{ productName: product[0].name, productDescription: product[0].description }}>
  // Actualizar meta tags dinámicamente cuando se cargue el producto
  if (typeof document !== 'undefined') {
    document.title = `${productName} - PROTON Fire & Rescue`;
    
    const metaDescription = document.querySelector('meta[name="description"]');
    if (metaDescription) {
      metaDescription.setAttribute('content', `${productDescription || productName} - Equipos de seguridad profesional para bomberos y rescate.`);
    }
    
    const ogTitle = document.querySelector('meta[property="og:title"]');
    if (ogTitle) {
      ogTitle.setAttribute('content', `${productName} - PROTON Fire & Rescue`);
    }
    
    const ogDescription = document.querySelector('meta[property="og:description"]');
    if (ogDescription) {
      ogDescription.setAttribute('content', `${productDescription || productName} - Equipos de seguridad profesional para bomberos y rescate.`);
    }
  }
</script>
