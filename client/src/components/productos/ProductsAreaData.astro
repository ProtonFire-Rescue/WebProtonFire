---
import {
  getProductsQuery,
  getCategoriesQuery,
  resolveBackendUrl,
} from "@/utils/server";
import { productUrl } from "@/utils/slugify";
const strapiBaseUrl = resolveBackendUrl({ astro: Astro });

const { data } = await getProductsQuery(
  "fields[0]=name&fields[1]=slug&populate[type][fields][0]=name&populate[model][fields][0]=name&populate[categories][fields][0]=name&populate[images][fields][0]=url&populate[brand][fields][0]=name&pagination[pageSize]=100&sort[0]=createdAt:desc",
  { cacheTtlMs: 15000, baseUrl: strapiBaseUrl, astro: Astro },
);

const { data: categories } = await getCategoriesQuery(
  "fields[0]=name&populate[mediaCategory][fields][0]=url&populate[mediaCategory][fields][1]=alternativeText",
  { cacheTtlMs: 15000, baseUrl: strapiBaseUrl, astro: Astro },
);

const imagesCategories: any[] = [{ name: "Otros", image: "/images/Otros.webp", alt: "Otros equipos que aun no pertenecen a una categoría." }];

const imageCategories = [...imagesCategories, ...categories.map((cat: any) => ({
  name: cat.name,
  image: cat.mediaCategory?.[0]?.url ?? "",
  alt: cat.mediaCategory?.[0]?.alternativeText ?? "",
}))];




type Card = {
  id: number;
  documentId: string;
  name: string;
  slug: string;
  image: string;
  category: string;
  model: string;
  brand: string;
};

const cards: Card[] = (data ?? []).flatMap((p: any) => {
  const categories = p.categories ?? [];
  if (categories.length === 0) {
    return [
      {
        id: p.id,
        documentId: p.documentId,
        name: p.name,
        slug: p.slug,
        image: p.images?.[0]?.url ?? "",
        category: "Otros",
        model: p.model?.name ?? "",
        brand: p.brand?.name ?? "",
      },
    ];
  }
  return categories.map((cat: any) => ({
    id: p.id,
    documentId: p.documentId,
    slug: p.slug,
    name: p.name,
    image: p.images?.[0]?.url ?? "",
    category: cat.name,
    model: p.model?.name ?? "",
    brand: p.brand?.name ?? "",
  }));
});

const groupNames = Array.from(new Set([...cards.map((c) => c.category)]));
const grouped = new Map<string, Card[]>();
for (const g of groupNames) grouped.set(g, []);
for (const c of cards) grouped.get(c.category)?.push(c);

const totalCount = cards.length;
---

{
  totalCount === 0 ? (
    <div class="text-center py-16">
      <p class="text-gray-500 dark:text-[#9ca3b8]">
        No hay productos disponibles
      </p>
    </div>
  ) : (
    <>
      {groupNames.map((groupName) => {
        const items = grouped.get(groupName) ?? [];
        return (
          <div class="mb-16 w-full" id={groupName.toLowerCase()}>
            <div class="relative w-full h-90 flex mb-10 items-center justify-center z-99">
              <h3 class="text-4xl font-semibold text-white mb-8 flex flex-col items-center gap-2" data-aos="fade-right">
                {groupName}
              </h3>

              {imageCategories.find((cat: any) => cat.name === groupName)
                ?.image && (
                <div
							class="absolute inset-0 bg-fixed bg-center bg-cover bg-no-repeat brightness-40 -z-10"
							style={`background-image: url(${imageCategories.find((cat: any) => cat.name === groupName)?.image}); background-blend-mode: overlay;`}
						>
						</div>
              )}
            </div>

            {items.length === 0 ? (
              <p class="text-sm text-gray-500 dark:text-[#9ca3b8]">
                No hay productos disponibles
              </p>
            ) : (
              <div>
                <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4 sm:gap-6">
                  {items.slice(0, 5).map((product) => (
                    <a
                      href={productUrl(product.category, product.slug)}
                      class="group bg-white dark:bg-[#1a1a2e] rounded-2xl border border-gray-100 dark:border-[#2a2a3e] hover:border-[#155DFC] overflow-hidden hover:shadow-xl dark:hover:shadow-black/30 transition-all duration-300 cursor-pointer"
                      data-aos="fade-up"
                    >
                      <div class="relative aspect-3/4 overflow-hidden bg-gray-50 dark:bg-[#12121e] p-4">
                        <img
                          src={product.image}
                          alt={product.name}
                          class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500"
                          loading="lazy"
                          width={300}
                          height={300}
                        />
                        <span class="absolute top-3 left-3 bg-[#155DFC]/90 text-white text-[11px] font-semibold px-2.5 py-1 rounded-full uppercase tracking-wider">
                          {product.category}
                        </span>
                      </div>
                      <div class="p-4">
                        <h4 class="font-semibold text-[#2f2f3b] dark:text-white text-base mb-1 uppercase tracking-wide">
                          {product.name}
                        </h4>
                        <p class="text-sm text-gray-400 dark:text-[#6b7280] mb-1">
                          {product.model}
                        </p>
                        <p class="text-sm text-[#155DFC] font-medium">
                          Marca: {product.brand}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
                {items.length > 4 && (
                  <div class="flex justify-center mt-8" data-aos="fade-up">
                    <a
                      href={`/catalogo/${encodeURIComponent(groupName)}`}
                      class="inline-flex items-center gap-2 bg-[#155DFC] text-white font-semibold px-8 py-3 rounded-full hover:bg-[#114ACA] transition-all duration-300 shadow-md shadow-[#155DFC]/20 hover:shadow-lg hover:shadow-[#155DFC]/30 hover:-translate-y-0.5 text-sm"
                    >
                      Ver todos los productos de {groupName}
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="m9 18 6-6-6-6" />
                      </svg>
                    </a>
                  </div>
                )}
              </div>
            )}
          </div>
        );
      })}
    </>
  )
}
