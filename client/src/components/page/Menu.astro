---
import { Image } from 'astro:assets';

export interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const menuItems = [
	{ href: '/productos', label: 'Productos', active: currentPath.startsWith('/productos') },
	{ href: '/servicios', label: 'Servicios', active: currentPath === '/servicios' },
	{ href: '/nosotros', label: 'Nosotros', active: currentPath === '/nosotros' }
];
---

<header  class="fixed top-3 sm:top-6 left-1/2 -translate-x-1/2 z-50 w-full max-w-225 px-3 sm:px-4" role="banner">
	<nav 
		id="main-nav"
		class="navigation bg-white/70 backdrop-blur-xl backdrop-saturate-150 border border-white/30 shadow-lg shadow-black/5 rounded-3xl px-4 sm:px-6 py-2.5 sm:py-3"
		role="navigation" 
		aria-label="Menú principal"
	>
		<!-- Top bar: logo + desktop links + hamburger -->
		<div class="flex items-center justify-between">
			<!-- Logo -->
			<a href="/" class="flex items-center shrink-0" aria-label="PROTON Fire & Rescue - Inicio">
				<Image 
					src="/logos/proton-logo.png" 
					alt="PROTON" 
					class="h-8 sm:h-10 w-auto"
					loading="lazy"
					width={100}
					height={100}
				/>
			</a>
			
			<!-- Desktop Menu - Centered -->
			<div class="hidden md:flex items-center gap-8 mx-auto">
				{menuItems.map((item) => (
					<a 
						href={item.href}
						class={`text-[14px] font-semibold transition-colors duration-200 ${
							item.active 
								? 'text-[#504aff]' 
								: 'text-[#2f2f3b] hover:text-[#504aff]'
						}`}
					>
						{item.label}
					</a>
				))}
			</div>
			
			<!-- CTA Button (Desktop) -->
			<a 
				href="/contactanos"
				class="hidden md:block bg-[#504aff] text-white text-[13px] font-semibold px-6 py-2.5 rounded-full hover:bg-[#3f3bcc] transition-all duration-200 shadow-md shadow-[#504aff]/20 hover:shadow-lg hover:shadow-[#504aff]/30 shrink-0"
			>
				Contáctanos
			</a>
			
			<!-- Mobile Menu Button -->
			<button 
				type="button"
				class="md:hidden p-1.5 text-[#2f2f3b] hover:text-[#504aff] transition-colors"
				aria-label="Abrir menú móvil"
				id="mobile-menu-button"
			>
				<!-- Hamburger icon -->
				<svg id="icon-hamburger" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
				<!-- Close icon (hidden by default) -->
				<svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
		</div>

		<!-- Mobile Menu (inside nav, animated with max-height) -->
		<div id="mobile-menu" class="md:hidden overflow-hidden max-h-0 opacity-0" style="transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.25s ease;">
			<div class="border-t border-gray-200/50 mt-3 pt-3 pb-1 space-y-1">
				{menuItems.map((item) => (
					<a 
						href={item.href}
						class={`mobile-menu-link block text-[14px] font-semibold py-2.5 px-3 rounded-xl transition-colors ${
							item.active 
								? 'text-[#504aff] bg-[#504aff]/10' 
								: 'text-[#2f2f3b] hover:bg-[#504aff]/5'
						}`}
					>
						{item.label}
					</a>
				))}
				<a 
					href="/contactanos"
					class="mobile-menu-link block bg-[#504aff] text-white text-[14px] font-semibold px-4 py-3 rounded-xl text-center shadow-md mt-2"
				>
					Contáctanos
				</a>
			</div>
		</div>
	</nav>
</header>

<style>
	#main-nav {
		transition: border-radius 0.3s cubic-bezier(0.4, 0, 0.2, 1),
		            background-color 0.3s ease,
		            box-shadow 0.3s ease;
	}
</style>

<script>
	function initMobileMenu() {
		const mobileMenuButton = document.getElementById('mobile-menu-button');
		const mobileMenu = document.getElementById('mobile-menu');
		const nav = document.getElementById('main-nav');
		const iconHamburger = document.getElementById('icon-hamburger');
		const iconClose = document.getElementById('icon-close');

		if (!mobileMenuButton || !mobileMenu || !nav || !iconHamburger || !iconClose) return;

		const menu = mobileMenu;
		const navEl = nav;

		// Remove existing listener to prevent duplicates
		const newButton = mobileMenuButton.cloneNode(true) as HTMLElement;
		mobileMenuButton.parentNode?.replaceChild(newButton, mobileMenuButton);

		// Re-query icons inside the cloned button
		const newIconHamburger = newButton.querySelector('#icon-hamburger');
		const newIconClose = newButton.querySelector('#icon-close');

		let isOpen = false;

		function openMenu() {
			isOpen = true;
			newButton.setAttribute('aria-expanded', 'true');
			// Animate border-radius first
			navEl.classList.remove('rounded-3xl');
			navEl.classList.add('rounded-2xl');
			// Slide open: measure content height and animate
			menu.style.maxHeight = menu.scrollHeight + 'px';
			menu.style.opacity = '1';
			// Toggle icons
			newIconHamburger?.classList.add('hidden');
			newIconClose?.classList.remove('hidden');
		}

		function closeMenu() {
			isOpen = false;
			newButton.setAttribute('aria-expanded', 'false');
			// Collapse the menu
			menu.style.maxHeight = '0';
			menu.style.opacity = '0';
			// Toggle icons
			newIconHamburger?.classList.remove('hidden');
			newIconClose?.classList.add('hidden');
			// Wait for animation to finish before restoring pill shape
			setTimeout(() => {
				if (!isOpen) {
					navEl.classList.remove('rounded-2xl');
					navEl.classList.add('rounded-3xl');
				}
			}, 350);
		}

		newButton.addEventListener('click', () => {
			const expanded = newButton.getAttribute('aria-expanded') === 'true';
			if (expanded) {
				closeMenu();
			} else {
				openMenu();
			}
		});

		// Close on outside click
		document.addEventListener('click', (e) => {
			if (isOpen && !navEl.contains(e.target as Node)) {
				closeMenu();
			}
		});

		// Close when a mobile link is clicked
		menu.querySelectorAll('.mobile-menu-link').forEach((link) => {
			link.addEventListener('click', () => closeMenu());
		});

		// Ensure menu starts closed
		menu.style.maxHeight = '0';
		menu.style.opacity = '0';
	}

	// Initialize on first load
	initMobileMenu();

	// Re-initialize after view transitions
	document.addEventListener('astro:page-load', initMobileMenu);
</script>
