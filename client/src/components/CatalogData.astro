---
import ProductCatalog from "./ProductCatalog";
import { BACKEND_URL } from "../utils/contants";
import { getProductsQuery } from "../utils/server";

const { data } = await getProductsQuery(
  'fields[0]=name&populate[category][fields][0]=name&populate[brand][fields][0]=name&populate[model][fields][0]=name&populate[images][fields][0]=url&pagination[pageSize]=100&sort[0]=createdAt:desc',
  { cacheTtlMs: 15000 },
);

const categories = [...new Set(data.map((product: any) => product.category.name))];
const brands = [...new Set(data.map((product: any) => product.brand.name))];

const allProducts = data.map((product: any) => {
  const { id, name, images, category: { name: category }, brand: { name: brand }, model: { name: model } } = product;
  return { id, name, image: `${BACKEND_URL}${images?.[0]?.url ?? ''}`, category, brand, model };
});
---

<ProductCatalog initialProducts={allProducts} categories={categories} brands={brands} client:load />
