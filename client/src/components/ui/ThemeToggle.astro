---
---

<button
  id="theme-toggle"
  type="button"
  class="fixed right-5 top-15 md:top-10  bg-white dark:bg-[#2f2f3b] z-10 p-4 rounded-full text-[#2f2f3b] dark:text-white/80 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors duration-200"
  aria-label="Cambiar tema"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg id="icon-sun" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <circle cx="12" cy="12" r="5" />
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg id="icon-moon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  function initThemeToggle() {
    const toggle = document.getElementById('theme-toggle')
    const iconSun = document.getElementById('icon-sun')
    const iconMoon = document.getElementById('icon-moon')
    if (!toggle || !iconSun || !iconMoon) return

    function applyTheme(dark: boolean) {
      document.documentElement.classList.toggle('dark', dark)
      iconSun.classList.toggle('hidden', !dark)
      iconMoon.classList.toggle('hidden', dark)
      localStorage.setItem('theme', dark ? 'dark' : 'light')
    }

    // Read stored preference or system preference
    const stored = localStorage.getItem('theme')
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
    const isDark = stored ? stored === 'dark' : prefersDark
    applyTheme(isDark)

    toggle.addEventListener('click', () => {
      const nowDark = document.documentElement.classList.contains('dark')
      applyTheme(!nowDark)
    })
  }

  initThemeToggle()
  document.addEventListener('astro:page-load', initThemeToggle)
</script>
