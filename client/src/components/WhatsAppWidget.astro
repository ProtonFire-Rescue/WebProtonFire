---
// Configuración del widget de WhatsApp
const whatsappNumber = "593982487322"; // Número de WhatsApp de PROTON
const defaultMessage = "Hola, me gustaría obtener más información sobre sus productos y servicios.";
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(defaultMessage)}`;
---

<!-- WhatsApp Floating Widget -->
<div class="fixed bottom-6 right-6 z-[1000]">
	<!-- Botón flotante principal -->
	<a 
		href={whatsappUrl}
		target="_blank"
		rel="noopener noreferrer"
		class="flex items-center gap-3 bg-gradient-to-br from-[#25D366] to-[#128C7E] text-white px-5 py-3.5 md:px-6 md:py-3.5 rounded-full shadow-lg shadow-[#25D366]/40 hover:shadow-xl hover:shadow-[#25D366]/60 transition-all duration-300 hover:-translate-y-0.5 hover:scale-105 animate-pulse-soft group"
		aria-label="Contactar por WhatsApp"
		id="whatsapp-button"
	>
		<svg class="w-7 h-7 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
			<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
		</svg>
		<span class="hidden md:block font-semibold text-[15px]">¿Necesitas ayuda?</span>
	</a>

	<!-- Tooltip -->
	<div 
		class="absolute bottom-20 right-0 w-[300px] sm:w-80 bg-white rounded-2xl shadow-2xl opacity-0 invisible translate-y-2 transition-all duration-300 ease-out"
		id="whatsapp-tooltip"
	>
		<div class="p-5">
			<!-- Header -->
			<div class="flex items-center gap-2.5 mb-3 text-[#128C7E]">
				<svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
					<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
				</svg>
				<span class="font-semibold text-base">PROTON Fire & Rescue</span>
				<button 
					class="ml-auto p-1 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded transition-colors"
					aria-label="Cerrar"
					id="close-tooltip"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
					</svg>
				</button>
			</div>
			
			<!-- Texto -->
			<p class="text-gray-600 text-sm leading-relaxed mb-4">
				¿Tienes alguna pregunta? Chatea con nosotros en WhatsApp
			</p>
			
			<!-- Botón CTA -->
			<a 
				href={whatsappUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="block w-full bg-gradient-to-br from-[#25D366] to-[#128C7E] text-white text-center py-3 rounded-lg font-semibold text-sm hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[#25D366]/30 transition-all duration-300"
			>
				Iniciar Chat
			</a>
		</div>
	</div>
</div>

<style>
	/* Animación de pulso suave personalizada */
	@keyframes pulse-soft {
		0%, 100% {
			box-shadow: 0 4px 12px rgba(37, 211, 102, 0.4);
		}
		50% {
			box-shadow: 0 4px 20px rgba(37, 211, 102, 0.6);
		}
	}

	.animate-pulse-soft {
		animation: pulse-soft 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
	}

	/* Mostrar tooltip */
	#whatsapp-tooltip.show {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}
</style>

<script>
	function initWhatsAppWidget() {
		const button = document.getElementById('whatsapp-button');
		const tooltip = document.getElementById('whatsapp-tooltip');
		const closeButton = document.getElementById('close-tooltip');
		
		if (!button || !tooltip || !closeButton) return;

		let tooltipTimeout: number;
		let hasShownTooltip = sessionStorage.getItem('whatsapp-tooltip-shown') === 'true';

		// Mostrar tooltip automáticamente después de 5 segundos (solo una vez por sesión)
		if (!hasShownTooltip) {
			tooltipTimeout = window.setTimeout(() => {
				tooltip.classList.add('show');
				sessionStorage.setItem('whatsapp-tooltip-shown', 'true');
				
				// Auto-cerrar después de 8 segundos
				setTimeout(() => {
					tooltip.classList.remove('show');
				}, 8000);
			}, 5000);
		}

		// Mostrar tooltip al hacer hover en el botón
		button.addEventListener('mouseenter', () => {
			clearTimeout(tooltipTimeout);
			tooltip.classList.add('show');
		});

		button.addEventListener('mouseleave', () => {
			setTimeout(() => {
				if (!tooltip.matches(':hover')) {
					tooltip.classList.remove('show');
				}
			}, 300);
		});

		tooltip.addEventListener('mouseleave', () => {
			tooltip.classList.remove('show');
		});

		// Cerrar tooltip
		closeButton.addEventListener('click', (e) => {
			e.preventDefault();
			e.stopPropagation();
			tooltip.classList.remove('show');
		});

		// Cerrar tooltip al hacer clic fuera
		document.addEventListener('click', (e) => {
			if (!button.contains(e.target as Node) && !tooltip.contains(e.target as Node)) {
				tooltip.classList.remove('show');
			}
		});
	}

	// Initialize on first load
	initWhatsAppWidget();

	// Re-initialize after view transitions
	document.addEventListener('astro:page-load', initWhatsAppWidget);
</script>
