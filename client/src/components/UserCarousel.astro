---
import { Image } from 'astro:assets';

interface User {
    name: string;
    bio: string;
    image: string;
}

interface Props {
    users: User[];
}

const { users } = Astro.props;
---

<section class="relative w-full max-w-6xl mx-auto px-4 py-5 rounded-[55px] overflow-hidden">
    <div class="flex items-center justify-center mb-10">

        <div class="flex gap-3">
            <button
                id="prevBtn"
                class="z-10 p-3 rounded-full border border-white/50 bg-white/5 text-black hover:bg-black hover:text-white transition-all duration-300 disabled:opacity-30"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m15 18-6-6 6-6"></path></svg
                >
            </button>
            <button
                id="nextBtn"
                class="z-10 p-3 rounded-full border border-white/50 bg-white/5 text-black hover:bg-black hover:text-white transition-all duration-300 disabled:opacity-30"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
                >
            </button>
        </div>
    </div>

    <div id="user-track" class="relative flex gap-6 transition-transform">
        {
            users.map((user) => (
                <div class="user-card flex-none w-[280px] md:w-[320px] group">
                    <div class="relative h-[400px] rounded-3xl overflow-hidden border border-white/5">
                        <Image
                            src={user.image}
                            alt={user.name}
                            class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-700 ease-out"
                            loading="eager"
                            width={320}
                            height={400}
                        />

                        <div class="absolute bottom-0 inset-x-0 p-6 bg-gradient-to-t from-black/90 via-black/40 to-transparent">
                            <div class="backdrop-blur-md bg-white/10 border border-white/20 rounded-2xl p-4 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                                <h3 class="text-xl font-semibold text-white">
                                    {user.name}
                                </h3>
                                <p class="text-zinc-300 text-sm italic">
                                    {user.bio}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
        
        <div
            class="absolute right-0 top-0 bottom-0 w-50 md:bg-linear-to-l from-zinc-200 via-zinc-200/80 to-transparent pointer-events-none"
        >
        </div>
</section>
<script>
    import { gsap } from "gsap";

    function initCarousel() {
        const track = document.getElementById("user-track");
        const cards = document.querySelectorAll(".user-card");
        const nextBtn = document.getElementById("nextBtn");
        const prevBtn = document.getElementById("prevBtn");

        if (!track || cards.length === 0) return;

        // 1. Forzamos el ancho del track para que no colapse
        // Calculamos el ancho de UNA tarjeta + su GAP
        const cardElement = cards[0] as HTMLElement;
        const style = window.getComputedStyle(track);
        const gap = parseInt(style.gap) || 24;
        const stepSize = cardElement.offsetWidth + gap;

        let currentIndex = 0;
        // Calculamos cuántas tarjetas caben en pantalla para no hacer scroll de más
        const visibleCards = Math.floor(
            track.parentElement!.offsetWidth / stepSize,
        );
        const maxIndex = cards.length - visibleCards;

        // 2. Función de movimiento limpia
        const moveTo = (index: number) => {
            currentIndex = Math.max(0, Math.min(index, maxIndex));

            gsap.to(track, {
                x: -currentIndex * stepSize,
                duration: 0.8,
                ease: "power4.out",
                overwrite: true, // Evita que se amontonen órdenes de movimiento
            });
        };

        // Eventos
        nextBtn?.addEventListener("click", () => moveTo(currentIndex + 1));
        prevBtn?.addEventListener("click", () => moveTo(currentIndex - 1));

        // 3. RE-CÁLCULO EN RESIZE (Fundamental para UX)
        window.addEventListener("resize", () => {
            // Si el usuario gira el móvil o cambia el tamaño, recalculamos el paso
            const newStep = cardElement.offsetWidth + gap;
            gsap.set(track, { x: -currentIndex * newStep });
        });
    }

    // Ejecutamos después de que Astro cargue la página
    document.addEventListener("astro:page-load", initCarousel);
    // Ejecución inicial segura
    window.addEventListener("load", initCarousel);
</script>
