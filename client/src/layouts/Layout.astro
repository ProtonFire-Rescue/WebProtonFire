---
import ThemeToggle from '@/components/ui/ThemeToggle.astro'
import '../styles/global.css'
import { Font } from 'astro:assets'
import { Toaster } from 'sonner'

export interface Props {
  title: string
  description: string
  image?: string
  url?: string
  type?: string
  keywords?: string
  author?: string
  jsonLd?: object | object[]
  canonical?: string
  productBrand?: string
  productAvailability?: string
}

const {
  title = 'PROTON Fire & Rescue - Equipos de Seguridad Ecuador',
  description = 'Empresa ecuatoriana con más de 2 décadas de trayectoria en importación y comercialización de equipos de seguridad para bomberos, rescate e industria.',
  image = '/images/og/og_home.webp',
  type = 'website',
  keywords = 'equipos bomberos, equipos rescate, seguridad industrial, PROTON Ecuador, equipos contra incendios, FLAIM, F-500, equipos emergencia',
  author = 'PROTON Fire & Rescue',
  jsonLd,
  canonical = Astro.url.href,
  productBrand,
  productAvailability = 'instock'
} = Astro.props



const siteOrigin = Astro.url.origin
const fullImageUrl = image.startsWith('http') ? image : `${siteOrigin}${image}`

// Structured Data base para la organización
const organizationSchema = {
  "@context": "https://schema.org",
  "@id": `${siteOrigin}/#organization`,
  "@type": "Organization",
  name: "PROTON Fire & Rescue Ecuador",
  alternateName: ["Proton Fire & Rescue", "PROTON Fire", "Proton Ecuador"],
  description: "Empresa ecuatoriana con más de 2 décadas de trayectoria en la importación y comercialización de equipos de seguridad para bomberos, rescate e industria. Distribuidores autorizados de marcas internacionales certificadas.",
  url: siteOrigin,
  logo: {
    "@type": "ImageObject",
    url: `${siteOrigin}/logos/proton-logo.webp`,
    width: 300,
    height: 200
  },
  image: `${siteOrigin}/images/og/og_home.webp`,
  contactPoint: [
    {
      "@type": "ContactPoint",
      telephone: "+593992526658",
      contactType: "sales",
      areaServed: "EC",
      availableLanguage: "es"
    },
    {
      "@type": "ContactPoint",
      telephone: "+593992526658",
      contactType: "customer service",
      areaServed: "EC",
      availableLanguage: "es"
    }
  ],
  email: "info@protonfire.com",
  sameAs: [
    "https://www.facebook.com/protonFireRescue",
    "https://www.instagram.com/proton_fire_/",
    "https://www.youtube.com/@protonfirerescue2360"
  ],
  address: {
    "@type": "PostalAddress",
    streetAddress: "Raúl González y Chimborazo Oe2-91",
    addressLocality: "Quito",
    addressRegion: "Pichincha",
    postalCode: "170136",
    addressCountry: "EC"
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: -0.20154376685984446,
    longitude: -78.43466760636124
  },
  areaServed: {
    "@type": "Country",
    name: "Ecuador"
  },
  foundingDate: "2000",
  slogan: "Protegiendo vidas, asegurando el futuro",
  numberOfEmployees: {
    "@type": "QuantitativeValue",
    minValue: 10,
    maxValue: 50
  },
  knowsAbout: [
    "Equipos de protección contra incendios",
    "Equipos de rescate vehicular",
    "Equipos SCBA",
    "Trajes estructurales para bomberos",
    "Trajes forestales",
    "Herramientas de rescate hidráulicas y eléctricas",
    "Agente encapsulador F-500 EA",
    "Realidad virtual para entrenamiento de bomberos FLAIM",
    "Equipos HAZMAT",
    "Capacitación y formación de brigadas"
  ],
  hasCredential: [
    { "@type": "EducationalOccupationalCredential", credentialCategory: "Distribuidor Autorizado", name: "Distribuidor Autorizado SICOR" },
    { "@type": "EducationalOccupationalCredential", credentialCategory: "Distribuidor Autorizado", name: "Distribuidor Autorizado Viking" },
    { "@type": "EducationalOccupationalCredential", credentialCategory: "Distribuidor Autorizado", name: "Distribuidor Autorizado FLAIM Systems" }
  ]
}

// Website schema
const websiteSchema = {
  '@context': 'https://schema.org',
  '@id': `${siteOrigin}/#website`,
  '@type': 'WebSite',
  name: 'PROTON Fire & Rescue Ecuador',
  alternateName: 'PROTON Fire',
  url: siteOrigin,
  inLanguage: 'es',
  publisher: { '@id': `${siteOrigin}/#organization` },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteOrigin}/catalogo/{search_term_string}`
    },
    'query-input': 'required name=search_term_string'
  }
}
---

<!doctype html>
<html lang='es'>
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme')
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark')
      }
    })()
  </script>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <link rel='icon' type='image/webp' href='/favicon.webp' />
    <meta name='generator' content={Astro.generator} />

    <!-- SEO Basics -->
    <title>{title}</title>
    <meta name='description' content={description} />
    <meta name='keywords' content={keywords} />
    <meta name='author' content={author} />
    <meta
      name='robots'
      content='index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'
    />
    <link rel='canonical' href={canonical} />

    <!-- Language and Geographic Targeting -->
    <meta name='language' content='Spanish' />
    <meta name='geo.region' content='EC' />
    <meta name='geo.placename' content='Ecuador' />

    <!-- Open Graph / Facebook -->
    <meta property='og:type' content={type} />
    <meta property='og:url' content={canonical} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:image' content={fullImageUrl} />
    <meta property='og:image:width' content='1200' />
    <meta property='og:image:height' content='630' />
    <meta property='og:image:alt' content={title} />
    <meta property='og:site_name' content='PROTON Fire & Rescue Ecuador' />
    <meta property='og:locale' content='es_EC' />
    {type === 'product' && productBrand && <meta property='product:brand' content={productBrand} />}
    {type === 'product' && <meta property='product:availability' content={productAvailability} />}
    {type === 'product' && <meta property='product:condition' content='new' />}

    <!-- Twitter -->
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:url' content={canonical} />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={fullImageUrl} />
    <meta name='twitter:image:alt' content={title} />
    <meta name='twitter:site' content='@protonfire' />
    <meta name='twitter:creator' content='@protonfire' />

    <!-- Additional SEO Meta Tags -->
    <meta name='format-detection' content='telephone=no' />
    <meta name='mobile-web-app-capable' content='yes' />
    <meta
      name='apple-mobile-web-app-status-bar-style'
      content='black-translucent'
    />
    <meta name='apple-mobile-web-app-title' content='PROTON Fire' />

    <!-- Theme Color -->
    <meta name='theme-color' content='#504aff' />
    <meta name='msapplication-TileColor' content='#504aff' />
    <meta name='msapplication-TileImage' content='/mstile-144x144.png' />

    <!-- Fonts (self-hosted via Astro Fonts API) -->
    <Font cssVariable="--font-questrial" />
    <Font cssVariable="--font-poppins" />
    <Font cssVariable="--font-google-sans" />

    <!-- Structured Data - Organization -->
    <script
      type='application/ld+json'
      set:html={JSON.stringify(organizationSchema)}
    />

    <!-- Structured Data - Website -->
    <script
      type='application/ld+json'
      set:html={JSON.stringify(websiteSchema)}
    />

    <!-- Google Analytics (deferred to not block LCP) -->
    <script>
      window.addEventListener('load', function () {
        setTimeout(function () {
          var s = document.createElement('script')
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-4EWT2XHH4X'
          s.async = true
          document.head.appendChild(s)
          s.onload = function () {
            window.dataLayer = window.dataLayer || []
            function gtag() { dataLayer.push(arguments) }
            gtag('js', new Date())
            gtag('config', 'G-4EWT2XHH4X')
          }
        }, 100)
      })
    </script>

    <!-- Page-specific Structured Data -->
    {
      jsonLd &&
        (Array.isArray(jsonLd) ? (
          jsonLd.map((schema) => (
            <script
              type='application/ld+json'
              set:html={JSON.stringify(schema)}
            />
          ))
        ) : (
          <script
            type='application/ld+json'
            set:html={JSON.stringify(jsonLd)}
          />
        ))
    }

    <!-- Preconnect to Cloudinary for image performance -->
    <link rel='preconnect' href='https://res.cloudinary.com' />
    <link rel='dns-prefetch' href='https://res.cloudinary.com' />

    <!-- AOS Animate On Scroll (non-render-blocking) -->
    <link rel='stylesheet' href='https://unpkg.com/aos@2.3.4/dist/aos.css' media='print' onload="this.media='all'" />
    <noscript><link rel='stylesheet' href='https://unpkg.com/aos@2.3.4/dist/aos.css' /></noscript>
  </head>
  <body id="main-content" class='relative font-sans antialiased bg-white dark:bg-[#0b0b12] text-[#2f2f3b] dark:text-[#e8e8f0] transition-colors duration-300'>
    
				<ThemeToggle />
    <Toaster client:idle transition:persist richColors={true} />
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    overflow-x: hidden;
    overflow-x: clip;
  }
</style>

<script>
  import AOS from 'aos'

  function initAOS() {
    AOS.init({
      duration: 700,
      easing: 'ease-out-cubic',
      once: true,
      offset: 50,
      disable: window.matchMedia('(prefers-reduced-motion: reduce)').matches
    })
  }

  initAOS()
  document.addEventListener('astro:page-load', () => {
    initAOS()
    AOS.refresh()
  })
</script>
