{
	"compatibility_date": "2026-03-20",
	"compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
	"name": "webprotonfire",
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"exclude": ["_worker.js/**"]
	},
	"observability": {
		"enabled": true
	}
}