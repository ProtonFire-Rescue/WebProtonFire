---
import Layout from '../layouts/Layout.astro';
import Menu from '../components/Menu.astro';
import Footer from '../components/Footer.astro';

const currentPath = Astro.url.pathname;
---

<Layout 
	title="Contáctanos - PROTON Fire & Rescue"
	description="Contacta con PROTON Fire & Rescue para obtener información sobre equipos de seguridad, capacitación y servicios para bomberos, rescate e industria."
	url="https://protonfire.com/contactanos"
>
	<Menu currentPath={currentPath} />
	
	<main>
		<!-- WhatsApp Hero Section -->
		<section class="relative py-20 bg-[#f8f9fa] overflow-hidden">
			<div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<!-- Image Side -->
					<div class="relative rounded-3xl overflow-hidden shadow-2xl">
						<img 
							src="/images/hero-home.png" 
							alt="Contact PROTON" 
							class="w-full h-[400px] lg:h-[500px] object-cover"
						/>
					</div>
					
					<!-- Content Side -->
					<div class="bg-white rounded-3xl p-8 lg:p-12 shadow-xl">
						<h2 class="text-3xl md:text-4xl font-bold text-[#2f2f3b] mb-4">
							Contáctanos
						</h2>
						<p class="text-lg text-[#6b7280] mb-6">
							Si te surgieron inquietudes o tienes alguna consulta, no dudes en contactarnos.
						</p>
						<p class="text-[#6b7280] mb-8">
							Nuestro equipo se ocupará de responder a tu inquietud lo más rápido posible.
						</p>
						<a 
							href="https://wa.me/593XXXXXXXXX"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-3 bg-[#25d366] text-white font-semibold px-8 py-4 rounded-full hover:bg-[#128c7e] transition-colors shadow-lg shadow-[#25d366]/30"
						>
							<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.521.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
							</svg>
							Contactanos por WhatsApp
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Contact Form & Info Section -->
		<section class="py-20 bg-white">
			<div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid lg:grid-cols-2 gap-12">
					<!-- Left Side - Globe/Info -->
					<div class="bg-[#504aff] rounded-3xl p-8 lg:p-12 text-white flex flex-col justify-center">
						<h3 class="text-2xl md:text-3xl font-bold mb-6">
							Y si quieres enviar tus dudas, inquietudes o requerimientos
						</h3>
						<p class="text-white/90 text-lg">
							Uno de los integrantes del equipo se pondrá en contacto contigo de inmediato.
						</p>
						<div class="mt-8 space-y-4">
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
									</svg>
								</div>
								<span>info@protonfire.com</span>
							</div>
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
									</svg>
								</div>
								<span>+593 XX XXX XXXX</span>
							</div>
						</div>
					</div>
					
					<!-- Right Side - Form -->
					<div class="bg-[#f8f9fa] rounded-3xl p-8 lg:p-12">
						<h3 class="text-2xl font-bold text-[#2f2f3b] mb-8">Envíanos un mensaje</h3>
						<form class="space-y-6" action="/contacto" method="POST">
							<div>
								<label for="nombre" class="block text-sm font-semibold text-[#2f2f3b] mb-2">Nombres y Apellidos *</label>
								<input 
									type="text" 
									id="nombre" 
									name="nombre" 
									required
									class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-[#504aff] focus:border-transparent transition-all"
									placeholder="Nombres y apellidos..."
								/>
							</div>
							
							<div>
								<label for="email" class="block text-sm font-semibold text-[#2f2f3b] mb-2">Email *</label>
								<input 
									type="email" 
									id="email" 
									name="email" 
									required
									class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-[#504aff] focus:border-transparent transition-all"
									placeholder="Email..."
								/>
							</div>
							
							<div>
								<label for="asunto" class="block text-sm font-semibold text-[#2f2f3b] mb-2">Asunto *</label>
								<input 
									type="text" 
									id="asunto" 
									name="asunto" 
									required
									class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-[#504aff] focus:border-transparent transition-all"
									placeholder="Asunto..."
								/>
							</div>
							
							<div>
								<label for="mensaje" class="block text-sm font-semibold text-[#2f2f3b] mb-2">Mensaje</label>
								<textarea 
									id="mensaje" 
									name="mensaje" 
									rows="4" 
									class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-[#504aff] focus:border-transparent transition-all resize-none"
									placeholder="Tu mensaje..."
								></textarea>
							</div>
							
							<button 
								type="submit" 
								class="w-full bg-[#504aff] text-white font-semibold py-4 px-8 rounded-full hover:bg-[#3f3bcc] transition-colors shadow-lg shadow-[#504aff]/30"
							>
								Contactanos
							</button>
						</form>
					</div>
				</div>
			</div>
		</section>

		<!-- Map / Visit Section -->
		<section class="py-20 bg-[#f8f9fa]">
			<div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<!-- Text Side -->
					<div>
						<h2 class="text-3xl md:text-4xl font-bold text-[#2f2f3b] mb-6">
							Si gustas visitar nuestras instalaciones, no dudes en hacerlo.
						</h2>
						<a 
							href="/contactanos"
							class="inline-flex items-center bg-[#504aff] text-white font-semibold px-8 py-4 rounded-full hover:bg-[#3f3bcc] transition-colors"
						>
							Contactanos
						</a>
					</div>
					
					<!-- Image Side -->
					<div class="relative rounded-3xl overflow-hidden shadow-2xl">
						<img 
							src="/images/linea-tecnologia.png" 
							alt="PROTON Location" 
							class="w-full h-[400px] object-cover"
						/>
					</div>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>
