---
import Layout from '../layouts/Layout.astro';
import Menu from '../components/Menu.astro';
import Footer from '../components/Footer.astro';

const currentPath = Astro.url.pathname;

const productCategories = [
	{
		name: 'Línea Fuego',
		description: 'Equipos especializados para la extinción de incendios y protección contra fuego',
		image: 'https://www.figma.com/api/mcp/asset/d59921bb-a034-47c7-a905-f2b5a6c3829d',
		products: ['Extintores', 'Mangueras', 'Equipos de respiración', 'Trajes de bombero']
	},
	{
		name: 'Línea Rescate',
		description: 'Equipos para operaciones de rescate y salvamento en emergencias',
		image: 'https://www.figma.com/api/mcp/asset/d59921bb-a034-47c7-a905-f2b5a6c3829d',
		products: ['Cuerdas', 'Arnés', 'Poleas', 'Herramientas de rescate']
	},
	{
		name: 'Línea Tecnología',
		description: 'Soluciones tecnológicas avanzadas para entrenamiento y operaciones',
		image: 'https://www.figma.com/api/mcp/asset/d59921bb-a034-47c7-a905-f2b5a6c3829d',
		products: ['F-500', 'FLAIM VR', 'Sistemas de monitoreo']
	}
];

const featuredProducts = [
	{
		name: 'F-500',
		description: 'Sistema de extinción eficaz',
		image: 'https://www.figma.com/api/mcp/asset/be2c6160-b9a7-403d-b147-99f7397c3de3',
		href: '/productos/f-500'
	},
	{
		name: 'FLAIM',
		description: 'Sistema de entrenamiento VR',
		image: 'https://www.figma.com/api/mcp/asset/be2c6160-b9a7-403d-b147-99f7397c3de3',
		href: '/productos/flaim'
	}
];

const brands = [
	{ name: 'F500', image: 'https://www.figma.com/api/mcp/asset/1925dca6-a831-4e10-8a6b-bf854cf0c01d' },
	{ name: 'Sicor', image: 'https://www.figma.com/api/mcp/asset/6eb7b505-adb5-46e1-a310-245958325d51' },
	{ name: 'Viking', image: 'https://www.figma.com/api/mcp/asset/98436151-63a9-40ef-87a1-75c2fb7f88a0' },
	{ name: 'Task', image: 'https://www.figma.com/api/mcp/asset/93f5eb13-5674-4a0c-a160-b5bd4d99d509' },
	{ name: 'Hystec', image: 'https://www.figma.com/api/mcp/asset/1b6440ea-a134-4c54-afe4-45578a62d954' },
	{ name: 'GVS', image: 'https://www.figma.com/api/mcp/asset/6cfba094-b3b1-40df-adc2-24efe10eade2' }
];
---

<Layout 
	title="Productos - PROTON Fire & Rescue"
	description="Descubre nuestro catálogo de equipos de seguridad para bomberos, rescate e industria. Trabajamos con las mejores marcas internacionales."
	url="https://protonfire.com/productos"
>
	<Menu currentPath={currentPath} />
	
	<main>
		<!-- Hero Section -->
		<section class="bg-[#504aff] py-20">
			<div class="max-w-[1440px] mx-auto px-4 text-center">
				<h1 class="text-4xl md:text-5xl lg:text-[52px] font-bold text-white mb-6">
					Nuestros Productos
				</h1>
				<p class="text-xl text-white/90 max-w-3xl mx-auto">
					Equipos de seguridad de las mejores marcas internacionales para bomberos, rescate e industria
				</p>
			</div>
		</section>

		<!-- Featured Products Section -->
		<section class="py-20 bg-[#f8f9fa]">
			<div class="max-w-[1414px] mx-auto px-4">
				<h2 class="text-3xl md:text-4xl lg:text-[52px] font-bold text-[#2f2f3b] text-center mb-4">
					Productos Destacados
				</h2>
				<p class="text-lg text-[#6b7280] text-center max-w-[692px] mx-auto mb-12">
					Te presentamos los productos que más llaman la atención de nuestros clientes
				</p>
				
				<div class="grid md:grid-cols-2 gap-8 max-w-[1185px] mx-auto">
					{featuredProducts.map((product) => (
						<div class="bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
							<div class="relative h-[552px] overflow-hidden">
								<img 
									src={product.image}
									alt={product.name}
									class="w-full h-full object-cover"
								/>
							</div>
							<div class="p-6">
								<h3 class="text-2xl font-bold text-[#2f2f3b] mb-2">{product.name}</h3>
								<p class="text-[#6b7280] mb-4">{product.description}</p>
								<a href={product.href} class="text-[#504aff] font-semibold hover:underline">
									Ver detalles del producto →
								</a>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Categories Section -->
		<section class="py-20 bg-white">
			<div class="max-w-[1414px] mx-auto px-4">
				<h2 class="text-3xl md:text-4xl lg:text-[52px] font-bold text-[#2f2f3b] text-center mb-12">
					Nuestras Líneas de Especialidad
				</h2>
				
				<div class="grid md:grid-cols-3 gap-8">
					{productCategories.map((category) => (
						<div class="group relative overflow-hidden rounded-2xl bg-white shadow-lg hover:shadow-xl transition-shadow">
							<div class="relative h-[413px] overflow-hidden">
								<img 
									src={category.image}
									alt={category.name}
									class="w-full h-full object-cover"
								/>
								<div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
								<div class="absolute bottom-0 left-0 right-0 p-6">
									<h3 class="text-2xl font-bold text-white mb-2">{category.name}</h3>
									<p class="text-white/80 text-sm">{category.description}</p>
								</div>
							</div>
							<div class="p-6">
								<ul class="space-y-2 mb-4">
									{category.products.map((product) => (
										<li class="flex items-center gap-2 text-[#6b7280]">
											<span class="w-1.5 h-1.5 bg-[#504aff] rounded-full"></span>
											{product}
										</li>
										))}
									</ul>
								<a 
									href={`/productos/category/${category.name.toLowerCase().replace(' ', '-')}`}
									class="text-[#504aff] font-semibold hover:underline"
								>
									Ver todos los productos →
								</a>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Brands Section -->
		<section class="py-20 bg-[#f8f9fa]">
			<div class="max-w-[1440px] mx-auto px-4">
				<h2 class="text-2xl md:text-3xl font-bold text-[#2f2f3b] text-center mb-12">
					Trabajamos con las mejores marcas del mercado
				</h2>
				
				<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 items-center justify-items-center">
					{brands.map((brand) => (
						<img 
							src={brand.image}
							alt={`${brand.name} Logo`}
							class="h-12 w-auto opacity-70 hover:opacity-100 transition-opacity"
						/>
					))}
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-20 bg-[#504aff]">
			<div class="max-w-[1440px] mx-auto px-4 text-center">
				<h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
					¿Necesitas más información?
				</h2>
				<p class="text-xl text-white/90 max-w-2xl mx-auto mb-8">
					Contáctanos para conocer nuestro catálogo completo y recibir asesoría personalizada
				</p>
				<a 
					href="/contactanos"
					class="inline-flex items-center bg-white text-[#504aff] font-semibold px-8 py-4 rounded-[25px] hover:bg-gray-100 transition-colors"
				>
					Contactanos
				</a>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>
