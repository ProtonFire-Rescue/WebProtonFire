];

const product = products[id as keyof typeof products];

// Si el producto no existe, redirigir al catálogo
if (!product) {
  return Astro.redirect("/catalogo");
}

const currentPath = Astro.url.pathname;
---

<Layout
  title={`${product.name} - PROTON Fire & Rescue`}
  description={`${product.name} - Equipos de seguridad profesional para bomberos y rescate. Certificado ${product.certification}.`}
  url={`https://protonfire.com/producto/${product.id}`}
>
  <Menu currentPath={currentPath} />
  
  <ProductDetail 
    product={product} 
    relatedProducts={relatedProducts}
    client:load
  />
  
  <Footer />
</Layout>
